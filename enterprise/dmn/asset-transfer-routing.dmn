<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="asset_transfer_routing_definitions"
             name="Asset Transfer Routing Definitions"
             namespace="http://werkflow.com/dmn">

  <decision id="asset_transfer_routing" name="Asset Transfer Routing">
    <description>Determines whether a manager sign-off is required for an asset transfer based on asset value.
Outputs requiresManagerApproval (boolean). This table answers the ROUTING question only —
it does not enforce per-user authorization limits.
Edit this table to adjust the high-value threshold without changing the BPMN process.</description>
    <decisionTable id="asset_transfer_routing_table" hitPolicy="FIRST">

      <input id="input_value" label="Asset Value">
        <inputExpression id="input_value_expr" typeRef="number">
          <text>assetValue</text>
        </inputExpression>
      </input>

      <output id="output_requires_manager" label="Requires Manager Approval" name="requiresManagerApproval" typeRef="boolean"/>
      <output id="output_transfer_path" label="Transfer Path" name="transferPath" typeRef="string"/>

      <!-- Rule 1: High-value assets require manager approval before transfer -->
      <rule id="rule_manager">
        <description>High-value assets require manager sign-off before custody transfer</description>
        <inputEntry id="rule_mgr_value"><text>&gt; 5000</text></inputEntry>
        <outputEntry id="rule_mgr_req"><text>true</text></outputEntry>
        <outputEntry id="rule_mgr_path"><text>"MANAGER_APPROVAL"</text></outputEntry>
      </rule>

      <!-- Rule 2: Standard assets proceed directly to custody transfer -->
      <rule id="rule_direct">
        <description>Standard-value assets proceed directly to new custodian acceptance</description>
        <inputEntry id="rule_dir_value"><text>&lt;= 5000</text></inputEntry>
        <outputEntry id="rule_dir_req"><text>false</text></outputEntry>
        <outputEntry id="rule_dir_path"><text>"DIRECT_TRANSFER"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram>
      <dmndi:DMNShape dmnElementRef="asset_transfer_routing">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
