<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="doa_routing_definitions"
             name="DoA Routing Definitions"
             namespace="http://werkflow.com/dmn">

  <decision id="doa_routing" name="Delegation of Authority Routing">
    <description>Routes approval requests to a workflow tier based on request amount.
The tier names (LEVEL_1, LEVEL_2, LEVEL_3, STANDARD) are generic placeholders —
organisations map these to their own approval roles via Keycloak group assignments.
This table answers the ROUTING question: which tier does this request go to?
It does NOT answer the AUTHORIZATION question: that is handled separately by the
doa_threshold table (DoaThresholdService), which controls the per-user approval limits
within each tier. Edit this table to change which requests flow to which approval level.
Do not hardcode role names, department names, or organisation-specific values here.</description>
    <decisionTable id="doa_routing_table" hitPolicy="FIRST">

      <input id="input_amount" label="Request Amount">
        <inputExpression id="input_amount_expr" typeRef="number">
          <text>requestAmount</text>
        </inputExpression>
      </input>

      <output id="output_approver" label="Approval Tier" name="approvalTier" typeRef="string"/>
      <output id="output_requires_escalation" label="Requires Escalation" name="requiresEscalation" typeRef="boolean"/>

      <!-- Rule 1: High-value — top-tier approval -->
      <rule id="rule_level1">
        <description>High-value requests require top-tier approval</description>
        <inputEntry id="rule_l1_amount"><text>&gt; 250000</text></inputEntry>
        <outputEntry id="rule_l1_tier"><text>"LEVEL_1"</text></outputEntry>
        <outputEntry id="rule_l1_esc"><text>true</text></outputEntry>
      </rule>

      <!-- Rule 2: Mid-high value — second-tier approval -->
      <rule id="rule_level2">
        <description>Mid-high value requests require second-tier approval</description>
        <inputEntry id="rule_l2_amount"><text>&gt; 100000</text></inputEntry>
        <outputEntry id="rule_l2_tier"><text>"LEVEL_2"</text></outputEntry>
        <outputEntry id="rule_l2_esc"><text>true</text></outputEntry>
      </rule>

      <!-- Rule 3: Mid-value — third-tier approval -->
      <rule id="rule_level3">
        <description>Mid-value requests require third-tier approval</description>
        <inputEntry id="rule_l3_amount"><text>&gt; 10000</text></inputEntry>
        <outputEntry id="rule_l3_tier"><text>"LEVEL_3"</text></outputEntry>
        <outputEntry id="rule_l3_esc"><text>false</text></outputEntry>
      </rule>

      <!-- Rule 4: Routine — standard approval -->
      <rule id="rule_standard">
        <description>Routine requests handled by standard approver</description>
        <inputEntry id="rule_std_amount"><text>&gt;= 0</text></inputEntry>
        <outputEntry id="rule_std_tier"><text>"STANDARD"</text></outputEntry>
        <outputEntry id="rule_std_esc"><text>false</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram>
      <dmndi:DMNShape dmnElementRef="doa_routing">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
