<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://werkflow.com/bpmn/examples">

  <process id="doa-routing-process" name="DoA Routing via DMN" isExecutable="true">

    <documentation>Demonstrates DMN-backed approval tier routing. A spend request is submitted,
then a Business Rule Task evaluates the doa_routing decision table to determine the approval
tier. The gateway routes to the appropriate task based on the DMN output — no hardcoded
thresholds in the BPMN. Edit doa-routing.dmn to define your organisation's own thresholds
and map the tier names (LEVEL_1, LEVEL_2, LEVEL_3, STANDARD) to your approval roles.</documentation>

    <startEvent id="doaStart" name="Request Submitted" flowable:initiator="initiator"/>

    <sequenceFlow id="flow_start_submit" sourceRef="doaStart" targetRef="submitRequest"/>

    <!-- Step 1: submitter fills in the spend request form -->
    <userTask id="submitRequest" name="Submit Spend Request"
              flowable:assignee="${initiator}"
              flowable:formKey="doa-request-form">
      <documentation>Submitter provides request amount and justification.</documentation>
    </userTask>

    <sequenceFlow id="flow_submit_route" sourceRef="submitRequest" targetRef="evaluateDoA"/>

    <!-- Step 2: Business Rule Task — evaluates doa_routing DMN decision table -->
    <!-- Output variable approvalTier is set from the DMN result -->
    <businessRuleTask id="evaluateDoA" name="Evaluate DoA Tier"
                      flowable:decisionRef="doa_routing"
                      flowable:mapDecisionResult="singleEntry"
                      flowable:resultVariable="approvalTier">
      <documentation>Evaluates the DoA routing decision table. Sets approvalTier to one of:
LEVEL_1, LEVEL_2, LEVEL_3, or STANDARD based on requestAmount. Map these tiers to your
organisation's approval roles in Keycloak — do not hardcode role names here.</documentation>
    </businessRuleTask>

    <sequenceFlow id="flow_route_gateway" sourceRef="evaluateDoA" targetRef="routeGateway"/>

    <!-- Step 3: gateway routes based on DMN output tier -->
    <exclusiveGateway id="routeGateway" name="Route by Approval Tier"/>

    <sequenceFlow id="flow_to_level1" sourceRef="routeGateway" targetRef="level1Approval">
      <conditionExpression xsi:type="tFormalExpression">${approvalTier == 'LEVEL_1'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow_to_level2" sourceRef="routeGateway" targetRef="level2Approval">
      <conditionExpression xsi:type="tFormalExpression">${approvalTier == 'LEVEL_2'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow_to_level3" sourceRef="routeGateway" targetRef="level3Approval">
      <conditionExpression xsi:type="tFormalExpression">${approvalTier == 'LEVEL_3'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow_to_standard" sourceRef="routeGateway" targetRef="standardApproval">
      <conditionExpression xsi:type="tFormalExpression">${approvalTier == 'STANDARD'}</conditionExpression>
    </sequenceFlow>

    <!-- Approval tasks — candidate groups reference Keycloak groups, configured per-org -->
    <userTask id="level1Approval" name="Level 1 Approval"
              flowable:candidateGroups="doa_approver_level1"
              flowable:formKey="doa-approval-form">
      <documentation>Top-tier approval for high-value requests.</documentation>
    </userTask>

    <userTask id="level2Approval" name="Level 2 Approval"
              flowable:candidateGroups="doa_approver_level2"
              flowable:formKey="doa-approval-form">
      <documentation>Second-tier approval for mid-high value requests.</documentation>
    </userTask>

    <userTask id="level3Approval" name="Level 3 Approval"
              flowable:candidateGroups="doa_approver_level3"
              flowable:formKey="doa-approval-form">
      <documentation>Third-tier approval for mid-value requests.</documentation>
    </userTask>

    <userTask id="standardApproval" name="Standard Approval"
              flowable:candidateGroups="doa_approver_level4"
              flowable:formKey="doa-approval-form">
      <documentation>Standard approval for routine requests.</documentation>
    </userTask>

    <!-- All paths converge at the join gateway -->
    <sequenceFlow id="flow_l1_join" sourceRef="level1Approval" targetRef="approvalJoin"/>
    <sequenceFlow id="flow_l2_join" sourceRef="level2Approval" targetRef="approvalJoin"/>
    <sequenceFlow id="flow_l3_join" sourceRef="level3Approval" targetRef="approvalJoin"/>
    <sequenceFlow id="flow_std_join" sourceRef="standardApproval" targetRef="approvalJoin"/>

    <exclusiveGateway id="approvalJoin" name="Approval Complete"/>

    <sequenceFlow id="flow_join_notify" sourceRef="approvalJoin" targetRef="sendOutcomeNotice"/>

    <serviceTask id="sendOutcomeNotice" name="Send Outcome Notification"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${emailActionDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>${initiator}</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>task-escalation</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <sequenceFlow id="flow_notify_end" sourceRef="sendOutcomeNotice" targetRef="doaEnd"/>

    <endEvent id="doaEnd" name="Request Complete"/>

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_doa-routing">
    <bpmndi:BPMNPlane id="BPMNPlane_doa-routing" bpmnElement="doa-routing-process">

      <bpmndi:BPMNShape id="doaStart_di" bpmnElement="doaStart">
        <omgdc:Bounds x="152" y="302" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="125" y="345" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="submitRequest_di" bpmnElement="submitRequest">
        <omgdc:Bounds x="240" y="280" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="evaluateDoA_di" bpmnElement="evaluateDoA">
        <omgdc:Bounds x="420" y="280" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="routeGateway_di" bpmnElement="routeGateway" isMarkerVisible="true">
        <omgdc:Bounds x="605" y="295" width="50" height="50"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="575" y="352" width="110" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="level1Approval_di" bpmnElement="level1Approval">
        <omgdc:Bounds x="730" y="100" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="level2Approval_di" bpmnElement="level2Approval">
        <omgdc:Bounds x="730" y="220" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="level3Approval_di" bpmnElement="level3Approval">
        <omgdc:Bounds x="730" y="340" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="standardApproval_di" bpmnElement="standardApproval">
        <omgdc:Bounds x="730" y="460" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="approvalJoin_di" bpmnElement="approvalJoin" isMarkerVisible="true">
        <omgdc:Bounds x="935" y="295" width="50" height="50"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="908" y="352" width="104" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="sendOutcomeNotice_di" bpmnElement="sendOutcomeNotice">
        <omgdc:Bounds x="1060" y="280" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="doaEnd_di" bpmnElement="doaEnd">
        <omgdc:Bounds x="1252" y="302" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="1225" y="345" width="90" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="flow_start_submit_di" bpmnElement="flow_start_submit">
        <omgdi:waypoint x="188" y="320"/>
        <omgdi:waypoint x="240" y="320"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_submit_route_di" bpmnElement="flow_submit_route">
        <omgdi:waypoint x="360" y="320"/>
        <omgdi:waypoint x="420" y="320"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_route_gateway_di" bpmnElement="flow_route_gateway">
        <omgdi:waypoint x="540" y="320"/>
        <omgdi:waypoint x="605" y="320"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_to_level1_di" bpmnElement="flow_to_level1">
        <omgdi:waypoint x="630" y="295"/>
        <omgdi:waypoint x="630" y="140"/>
        <omgdi:waypoint x="730" y="140"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_to_level2_di" bpmnElement="flow_to_level2">
        <omgdi:waypoint x="630" y="295"/>
        <omgdi:waypoint x="630" y="260"/>
        <omgdi:waypoint x="730" y="260"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_to_level3_di" bpmnElement="flow_to_level3">
        <omgdi:waypoint x="630" y="345"/>
        <omgdi:waypoint x="630" y="380"/>
        <omgdi:waypoint x="730" y="380"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_to_standard_di" bpmnElement="flow_to_standard">
        <omgdi:waypoint x="630" y="345"/>
        <omgdi:waypoint x="630" y="500"/>
        <omgdi:waypoint x="730" y="500"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_l1_join_di" bpmnElement="flow_l1_join">
        <omgdi:waypoint x="850" y="140"/>
        <omgdi:waypoint x="960" y="140"/>
        <omgdi:waypoint x="960" y="295"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_l2_join_di" bpmnElement="flow_l2_join">
        <omgdi:waypoint x="850" y="260"/>
        <omgdi:waypoint x="960" y="260"/>
        <omgdi:waypoint x="960" y="295"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_l3_join_di" bpmnElement="flow_l3_join">
        <omgdi:waypoint x="850" y="380"/>
        <omgdi:waypoint x="960" y="380"/>
        <omgdi:waypoint x="960" y="345"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_std_join_di" bpmnElement="flow_std_join">
        <omgdi:waypoint x="850" y="500"/>
        <omgdi:waypoint x="960" y="500"/>
        <omgdi:waypoint x="960" y="345"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_join_notify_di" bpmnElement="flow_join_notify">
        <omgdi:waypoint x="985" y="320"/>
        <omgdi:waypoint x="1060" y="320"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_notify_end_di" bpmnElement="flow_notify_end">
        <omgdi:waypoint x="1180" y="320"/>
        <omgdi:waypoint x="1252" y="320"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
