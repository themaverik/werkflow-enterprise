<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://werkflow.com/bpmn/examples">

  <process id="sla-escalation" name="SLA Escalation Process" isExecutable="true">

    <documentation>Demonstrates timer boundary events. A review task must be completed within 72 hours.
At 48 hours a non-interrupting reminder email is sent to the initiator. At 72 hours an
interrupting escalation reassigns the work to a senior approver.</documentation>

    <!-- Start: initiator kicks off the review -->
    <startEvent id="slaStart" name="Start Review" flowable:initiator="initiator"/>

    <sequenceFlow id="flow_start_review" sourceRef="slaStart" targetRef="reviewItem"/>

    <!-- Main review task — reviewer has 72 h before escalation fires -->
    <userTask id="reviewItem" name="Review Item"
              flowable:candidateGroups="WORKFLOW_ADMIN,ADMIN"
              flowable:formKey="sla-escalation-decision">
      <documentation>Complete within 72 hours. A reminder fires at 48 hours.</documentation>
    </userTask>

    <!-- Non-interrupting timer: fires at 48 h, sends reminder, task continues -->
    <boundaryEvent id="reminderTimer" name="48h Reminder" attachedToRef="reviewItem"
                   cancelActivity="false">
      <timerEventDefinition id="reminderTimerDef">
        <timeDuration>PT48H</timeDuration>
      </timerEventDefinition>
    </boundaryEvent>

    <!-- Interrupting timer: fires at 72 h, cancels the task and escalates -->
    <boundaryEvent id="escalationTimer" name="72h Escalation" attachedToRef="reviewItem"
                   cancelActivity="true">
      <timerEventDefinition id="escalationTimerDef">
        <timeDuration>PT72H</timeDuration>
      </timerEventDefinition>
    </boundaryEvent>

    <!-- Reminder path -->
    <sequenceFlow id="flow_reminder" sourceRef="reminderTimer" targetRef="sendReminder"/>

    <serviceTask id="sendReminder" name="Send Reminder Email"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${emailActionDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>${initiator}</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>task-reminder</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <sequenceFlow id="flow_reminder_end" sourceRef="sendReminder" targetRef="reminderEnd"/>

    <endEvent id="reminderEnd" name="Reminder Sent"/>

    <!-- Escalation path -->
    <sequenceFlow id="flow_escalate" sourceRef="escalationTimer" targetRef="escalateTask"/>

    <userTask id="escalateTask" name="Escalated Review"
              flowable:candidateGroups="ADMIN,SUPER_ADMIN"
              flowable:formKey="sla-escalation-decision">
      <documentation>Task escalated due to SLA breach. Senior approver must complete.</documentation>
    </userTask>

    <sequenceFlow id="flow_escalate_notify" sourceRef="escalateTask" targetRef="sendEscalationEmail"/>

    <serviceTask id="sendEscalationEmail" name="Send Escalation Email"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${emailActionDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>${initiator}</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>task-escalation</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <sequenceFlow id="flow_escalation_end" sourceRef="sendEscalationEmail" targetRef="escalationEnd"/>

    <endEvent id="escalationEnd" name="Escalated End"/>

    <!-- Normal completion -->
    <sequenceFlow id="flow_review_done" sourceRef="reviewItem" targetRef="slaEnd"/>

    <endEvent id="slaEnd" name="Review Complete"/>

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_sla-escalation">
    <bpmndi:BPMNPlane id="BPMNPlane_sla-escalation" bpmnElement="sla-escalation">

      <bpmndi:BPMNShape id="slaStart_di" bpmnElement="slaStart">
        <omgdc:Bounds x="152" y="212" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="137" y="255" width="67" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="reviewItem_di" bpmnElement="reviewItem">
        <omgdc:Bounds x="240" y="190" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="reminderTimer_di" bpmnElement="reminderTimer">
        <omgdc:Bounds x="262" y="252" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="243" y="295" width="74" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="escalationTimer_di" bpmnElement="escalationTimer">
        <omgdc:Bounds x="322" y="252" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="303" y="295" width="74" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="sendReminder_di" bpmnElement="sendReminder">
        <omgdc:Bounds x="230" y="360" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="reminderEnd_di" bpmnElement="reminderEnd">
        <omgdc:Bounds x="272" y="492" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="249" y="535" width="82" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="escalateTask_di" bpmnElement="escalateTask">
        <omgdc:Bounds x="430" y="360" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="sendEscalationEmail_di" bpmnElement="sendEscalationEmail">
        <omgdc:Bounds x="600" y="360" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="escalationEnd_di" bpmnElement="escalationEnd">
        <omgdc:Bounds x="702" y="492" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="675" y="535" width="90" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="slaEnd_di" bpmnElement="slaEnd">
        <omgdc:Bounds x="452" y="212" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="426" y="255" width="88" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="flow_start_review_di" bpmnElement="flow_start_review">
        <omgdi:waypoint x="188" y="230"/>
        <omgdi:waypoint x="240" y="230"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_review_done_di" bpmnElement="flow_review_done">
        <omgdi:waypoint x="360" y="230"/>
        <omgdi:waypoint x="452" y="230"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_reminder_di" bpmnElement="flow_reminder">
        <omgdi:waypoint x="280" y="288"/>
        <omgdi:waypoint x="280" y="360"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_reminder_end_di" bpmnElement="flow_reminder_end">
        <omgdi:waypoint x="290" y="440"/>
        <omgdi:waypoint x="290" y="492"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_escalate_di" bpmnElement="flow_escalate">
        <omgdi:waypoint x="340" y="288"/>
        <omgdi:waypoint x="490" y="360"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_escalate_notify_di" bpmnElement="flow_escalate_notify">
        <omgdi:waypoint x="550" y="400"/>
        <omgdi:waypoint x="600" y="400"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_escalation_end_di" bpmnElement="flow_escalation_end">
        <omgdi:waypoint x="720" y="440"/>
        <omgdi:waypoint x="720" y="492"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
