<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="doa_routing_definitions"
             name="DoA Routing Definitions"
             namespace="http://werkflow.com/dmn">

  <decision id="doa_routing" name="Delegation of Authority Routing">
    <description>Routes approval requests to the correct approver group based on request
amount and department. Used by BPMN Business Rule Tasks to replace hardcoded
JUEL gateway conditions with externally-managed thresholds.</description>
    <decisionTable id="doa_routing_table" hitPolicy="FIRST">

      <input id="input_amount" label="Request Amount">
        <inputExpression id="input_amount_expr" typeRef="number">
          <text>requestAmount</text>
        </inputExpression>
      </input>

      <input id="input_department" label="Department">
        <inputExpression id="input_department_expr" typeRef="string">
          <text>department</text>
        </inputExpression>
      </input>

      <output id="output_approver" label="Approver Group" name="approverGroup" typeRef="string"/>
      <output id="output_director" label="Requires Director" name="requiresDirector" typeRef="boolean"/>
      <output id="output_vp" label="Requires VP" name="requiresVP" typeRef="boolean"/>

      <!-- Rule 1: > 250,000 — always VP regardless of department -->
      <rule id="rule_vp">
        <description>Amounts exceeding 250k require VP approval regardless of department</description>
        <inputEntry id="rule_vp_amount"><text>&gt; 250000</text></inputEntry>
        <inputEntry id="rule_vp_dept"><text></text></inputEntry>
        <outputEntry id="rule_vp_group"><text>"VP"</text></outputEntry>
        <outputEntry id="rule_vp_director"><text>true</text></outputEntry>
        <outputEntry id="rule_vp_vp"><text>true</text></outputEntry>
      </rule>

      <!-- Rule 2: > 150,000 in FINANCE — Finance Director -->
      <rule id="rule_finance_director">
        <description>Finance amounts over 150k require Finance Director approval</description>
        <inputEntry id="rule_fd_amount"><text>&gt; 150000</text></inputEntry>
        <inputEntry id="rule_fd_dept"><text>"FINANCE"</text></inputEntry>
        <outputEntry id="rule_fd_group"><text>"FINANCE_DIRECTOR"</text></outputEntry>
        <outputEntry id="rule_fd_director"><text>true</text></outputEntry>
        <outputEntry id="rule_fd_vp"><text>false</text></outputEntry>
      </rule>

      <!-- Rule 3: > 100,000 — Manager approval -->
      <rule id="rule_manager">
        <description>Amounts over 100k require manager approval</description>
        <inputEntry id="rule_mgr_amount"><text>&gt; 100000</text></inputEntry>
        <inputEntry id="rule_mgr_dept"><text></text></inputEntry>
        <outputEntry id="rule_mgr_group"><text>"MANAGER"</text></outputEntry>
        <outputEntry id="rule_mgr_director"><text>false</text></outputEntry>
        <outputEntry id="rule_mgr_vp"><text>false</text></outputEntry>
      </rule>

      <!-- Rule 4: All other amounts — standard staff approval -->
      <rule id="rule_staff">
        <description>All other requests handled by staff approver</description>
        <inputEntry id="rule_staff_amount"><text>&gt;= 0</text></inputEntry>
        <inputEntry id="rule_staff_dept"><text></text></inputEntry>
        <outputEntry id="rule_staff_group"><text>"STAFF"</text></outputEntry>
        <outputEntry id="rule_staff_director"><text>false</text></outputEntry>
        <outputEntry id="rule_staff_vp"><text>false</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
