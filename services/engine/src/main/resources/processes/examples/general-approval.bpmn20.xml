        <omgdc:Bounds x="152" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="131" y="305" width="78" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="submitRequest_di" bpmnElement="submitRequest">
        <omgdc:Bounds x="240" y="240" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="managerApproval_di" bpmnElement="managerApproval">
        <omgdc:Bounds x="395" y="240" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="managerDecisionGateway_di" bpmnElement="managerDecisionGateway" isMarkerVisible="true">
        <omgdc:Bounds x="555" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="538" y="312" width="84" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="amountGateway_di" bpmnElement="amountGateway" isMarkerVisible="true">
        <omgdc:Bounds x="665" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="640" y="312" width="100" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="directorApproval_di" bpmnElement="directorApproval">
        <omgdc:Bounds x="770" y="150" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="mergeGateway_di" bpmnElement="mergeGateway" isMarkerVisible="true">
        <omgdc:Bounds x="935" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="944" y="312" width="33" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="sendApprovedEmail_di" bpmnElement="sendApprovedEmail">
        <omgdc:Bounds x="1045" y="170" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="sendRejectedEmail_di" bpmnElement="sendRejectedEmail">
        <omgdc:Bounds x="1045" y="330" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="endApproved_di" bpmnElement="endApproved">
        <omgdc:Bounds x="1207" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="1184" y="235" width="82" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="endRejected_di" bpmnElement="endRejected">
        <omgdc:Bounds x="1207" y="352" width="36" height="36" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="1184" y="395" width="82" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="flow1_di" bpmnElement="flow1">
        <omgdi:waypoint x="188" y="280" /><omgdi:waypoint x="240" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow2_di" bpmnElement="flow2">
        <omgdi:waypoint x="340" y="280" /><omgdi:waypoint x="395" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow3_di" bpmnElement="flow3">
        <omgdi:waypoint x="495" y="280" /><omgdi:waypoint x="555" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow4_di" bpmnElement="flow4">
        <omgdi:waypoint x="605" y="280" /><omgdi:waypoint x="665" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow5_di" bpmnElement="flow5">
        <omgdi:waypoint x="580" y="305" /><omgdi:waypoint x="580" y="370" /><omgdi:waypoint x="1045" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow6_di" bpmnElement="flow6">
        <omgdi:waypoint x="690" y="255" /><omgdi:waypoint x="690" y="190" /><omgdi:waypoint x="770" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow7_di" bpmnElement="flow7">
