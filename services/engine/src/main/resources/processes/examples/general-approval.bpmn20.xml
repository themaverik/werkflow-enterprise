      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow8_di" bpmnElement="flow8">
        <omgdi:waypoint x="870" y="190" /><omgdi:waypoint x="960" y="190" /><omgdi:waypoint x="960" y="255" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow9_di" bpmnElement="flow9">
        <omgdi:waypoint x="960" y="255" /><omgdi:waypoint x="960" y="210" /><omgdi:waypoint x="1045" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow10_di" bpmnElement="flow10">
        <omgdi:waypoint x="960" y="305" /><omgdi:waypoint x="960" y="370" /><omgdi:waypoint x="1045" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow11_di" bpmnElement="flow11">
        <omgdi:waypoint x="1145" y="210" /><omgdi:waypoint x="1207" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow12_di" bpmnElement="flow12">
