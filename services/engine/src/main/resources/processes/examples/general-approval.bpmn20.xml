<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://werkflow.com/bpmn/examples">

  <process id="general-approval" name="General Approval" isExecutable="true">

    <documentation>General-purpose approval workflow. Demonstrates DOA-based routing: requests up to $50K require Manager approval only; requests over $50K also require Director approval. Engine-internal — no external API calls.</documentation>

    <!-- Start: Employee submits request -->
    <startEvent id="startEvent" name="Request Submitted" flowable:initiator="initiator">
      <documentation>Employee submits a general approval request</documentation>
    </startEvent>

    <!-- Step 1: Employee fills in request details -->
    <userTask id="submitRequest" name="Submit Request"
              flowable:assignee="${initiator}"
              flowable:formKey="general-approval-form">
      <documentation>Employee provides title, description, amount, and category</documentation>
    </userTask>

    <!-- Step 2: Manager always reviews first (DOA_L2 = doa_approver_level2 in Keycloak) -->
    <userTask id="managerApproval" name="Manager Approval"
              flowable:candidateGroups="DOA_L2,SUPER_ADMIN"
              flowable:formKey="general-approval-decision">
      <documentation>Manager reviews the request and sets decision = approve or reject</documentation>
      <extensionElements>
        <flowable:field name="outcomeVariable"><flowable:string>decision</flowable:string></flowable:field>
      </extensionElements>
    </userTask>

    <!-- Gateway: check if manager rejected — if so, skip amount check -->
    <exclusiveGateway id="managerDecisionGateway" name="Manager Decision?" />

    <!-- Gateway: if approved, check if amount requires director sign-off -->
    <exclusiveGateway id="amountGateway" name="Requires Director Approval?" />

    <!-- Step 3 (high-amount path): Director also reviews -->
    <userTask id="directorApproval" name="Director Approval"
              flowable:candidateGroups="DOA_L3,DOA_L4,SUPER_ADMIN"
              flowable:formKey="general-approval-decision">
      <documentation>Director reviews high-value requests (amount > $50,000) and sets decision = approve or reject</documentation>
      <extensionElements>
        <flowable:field name="outcomeVariable"><flowable:string>decision</flowable:string></flowable:field>
      </extensionElements>
    </userTask>

    <!-- Merge gateway: combines both amount paths before notification -->
    <exclusiveGateway id="mergeGateway" name="Merge" />

    <!-- Notification: send result email to initiator -->
    <serviceTask id="sendApprovedEmail" name="Notify: Approved"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${emailActionDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>${initiator}</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>request-approved</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <serviceTask id="sendRejectedEmail" name="Notify: Rejected"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${emailActionDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>${initiator}</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>request-rejected</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <endEvent id="endApproved" name="Request Approved" />
    <endEvent id="endRejected" name="Request Rejected" />

    <!-- Sequence flows -->
    <sequenceFlow id="flow1" sourceRef="startEvent"            targetRef="submitRequest" />
    <sequenceFlow id="flow2" sourceRef="submitRequest"         targetRef="managerApproval" />
    <sequenceFlow id="flow3" sourceRef="managerApproval"       targetRef="managerDecisionGateway" />

    <sequenceFlow id="flow4" sourceRef="managerDecisionGateway" targetRef="amountGateway">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'approve'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow5" sourceRef="managerDecisionGateway" targetRef="sendRejectedEmail">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'reject'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow6" sourceRef="amountGateway" targetRef="directorApproval">
      <conditionExpression xsi:type="tFormalExpression">${amount > 50000}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow7" sourceRef="amountGateway" targetRef="mergeGateway">
      <conditionExpression xsi:type="tFormalExpression">${amount &lt;= 50000}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow8" sourceRef="directorApproval"      targetRef="mergeGateway" />
    <sequenceFlow id="flow9" sourceRef="mergeGateway"          targetRef="sendApprovedEmail">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'approve'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow10" sourceRef="mergeGateway"         targetRef="sendRejectedEmail">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'reject'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow11" sourceRef="sendApprovedEmail"    targetRef="endApproved" />
    <sequenceFlow id="flow12" sourceRef="sendRejectedEmail"    targetRef="endRejected" />

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_general-approval">
    <bpmndi:BPMNPlane id="BPMNPlane_general-approval" bpmnElement="general-approval">

