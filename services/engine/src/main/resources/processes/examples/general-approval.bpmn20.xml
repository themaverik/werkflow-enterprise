<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://werkflow.com/bpmn/examples">

  <process id="general-approval" name="General Approval" isExecutable="true"
           flowable:versionTag="2">

    <documentation>General-purpose approval workflow — V2 per-level decision routing (ADR-027).
Manager always reviews first. If approved and amount &gt; $50,000, Director also reviews.
Each level has its own decision gateway (approve/reject/escalate), giving early-exit on reject
and a safe escalate path. Director is the top level; no escalate route from Director (portal
suppresses the Escalate button at top level). Engine-internal — no external API calls.
Email notifications are sent automatically by GlobalTaskNotificationListener on task assignment
and completion.</documentation>

    <extensionElements>
      <flowable:properties>
        <flowable:property name="category" value="examples"/>
      </flowable:properties>
    </extensionElements>

    <!-- Start: Employee submits request -->
    <startEvent id="startEvent" name="Request Submitted" flowable:initiator="initiator">
      <documentation>Employee submits a general approval request</documentation>
    </startEvent>

    <!-- Step 1: Employee fills in request details -->
    <userTask id="submitRequest" name="Submit Request"
              flowable:assignee="${initiator}"
              flowable:formKey="general-approval-form">
      <documentation>Employee provides title, description, amount, and category</documentation>
    </userTask>

    <!-- Step 2: Manager always reviews first (DOA_L2) -->
    <userTask id="managerApproval" name="Manager Approval"
              flowable:candidateGroups="DOA_L2,SUPER_ADMIN"
              flowable:formKey="general-approval-decision">
      <documentation>Manager reviews the request. Sets decision = approve, reject, or escalate.</documentation>
    </userTask>

    <!-- Per-level decision gateway: Manager -->
    <exclusiveGateway id="managerDecisionGateway" name="Manager Decision?" />

    <!-- Amount threshold after manager approve (not taken on escalate) -->
    <exclusiveGateway id="amountGateway" name="Requires Director Approval?" />

    <!-- Step 3 (high-amount or escalate path): Director reviews -->
    <userTask id="directorApproval" name="Director Approval"
              flowable:candidateGroups="DOA_L3,DOA_L4,SUPER_ADMIN"
              flowable:formKey="general-approval-decision">
      <documentation>Director reviews high-value requests (amount &gt; $50,000) or escalated requests.
Sets decision = approve or reject. Director is the top level — no escalate route.</documentation>
    </userTask>

    <!-- Per-level decision gateway: Director (top level — no escalate route) -->
    <exclusiveGateway id="directorDecisionGateway" name="Director Decision?" />

    <endEvent id="endApproved" name="Request Approved" />
    <endEvent id="endRejected" name="Request Rejected" />

    <!-- Sequence flows -->
    <sequenceFlow id="flow1" sourceRef="startEvent"       targetRef="submitRequest" />
    <sequenceFlow id="flow2" sourceRef="submitRequest"    targetRef="managerApproval" />
    <sequenceFlow id="flow3" sourceRef="managerApproval"  targetRef="managerDecisionGateway" />

    <!-- managerDecisionGateway branches -->
    <sequenceFlow id="flow4" sourceRef="managerDecisionGateway" targetRef="endRejected">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'reject'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow5" sourceRef="managerDecisionGateway" targetRef="amountGateway">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'approve'}</conditionExpression>
    </sequenceFlow>
    <!-- manager escalate → director directly, regardless of amount -->
    <sequenceFlow id="flow5e" sourceRef="managerDecisionGateway" targetRef="directorApproval">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'escalate'}</conditionExpression>
    </sequenceFlow>

    <!-- amountGateway branches (only reached on manager approve) -->
    <sequenceFlow id="flow6" sourceRef="amountGateway" targetRef="directorApproval">
      <conditionExpression xsi:type="tFormalExpression">${amount > 50000}</conditionExpression>
    </sequenceFlow>
    <!-- amount<=50000: manager-approved, no higher level needed → end approved -->
    <sequenceFlow id="flow7" sourceRef="amountGateway" targetRef="endApproved">
      <conditionExpression xsi:type="tFormalExpression">${amount &lt;= 50000}</conditionExpression>
    </sequenceFlow>

    <!-- Director → directorDecisionGateway -->
    <sequenceFlow id="flow8" sourceRef="directorApproval" targetRef="directorDecisionGateway" />

    <!-- directorDecisionGateway branches (approve/reject only — no escalate at top level) -->
    <sequenceFlow id="flow9" sourceRef="directorDecisionGateway" targetRef="endApproved">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'approve'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow10" sourceRef="directorDecisionGateway" targetRef="endRejected">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'reject'}</conditionExpression>
    </sequenceFlow>

  </process>

  <!--
    BPMNDI — left-to-right layout.
    Main flow at y=280. Director level at y=150.
    Manager reject routes down to endRejected at y=420.
    Director decision gateway at x=1050.
  -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_general-approval">
    <bpmndi:BPMNPlane id="BPMNPlane_general-approval" bpmnElement="general-approval">

      <bpmndi:BPMNShape id="startEvent_di" bpmnElement="startEvent">
        <omgdc:Bounds x="152" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="131" y="305" width="78" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="submitRequest_di" bpmnElement="submitRequest">
        <omgdc:Bounds x="240" y="240" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="managerApproval_di" bpmnElement="managerApproval">
        <omgdc:Bounds x="395" y="240" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Per-level gateway: Manager -->
      <bpmndi:BPMNShape id="managerDecisionGateway_di" bpmnElement="managerDecisionGateway" isMarkerVisible="true">
        <omgdc:Bounds x="555" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="534" y="312" width="92" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Amount gateway -->
      <bpmndi:BPMNShape id="amountGateway_di" bpmnElement="amountGateway" isMarkerVisible="true">
        <omgdc:Bounds x="670" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="640" y="312" width="110" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Director approval (upper lane) -->
      <bpmndi:BPMNShape id="directorApproval_di" bpmnElement="directorApproval">
        <omgdc:Bounds x="800" y="140" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Per-level gateway: Director -->
      <bpmndi:BPMNShape id="directorDecisionGateway_di" bpmnElement="directorDecisionGateway" isMarkerVisible="true">
        <omgdc:Bounds x="960" y="155" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="938" y="212" width="94" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- End events -->
      <bpmndi:BPMNShape id="endApproved_di" bpmnElement="endApproved">
        <omgdc:Bounds x="1112" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="1088" y="205" width="84" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="endRejected_di" bpmnElement="endRejected">
        <omgdc:Bounds x="557" y="420" width="36" height="36" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="533" y="463" width="84" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Edges -->
      <bpmndi:BPMNEdge id="flow1_di" bpmnElement="flow1">
        <omgdi:waypoint x="188" y="280" /><omgdi:waypoint x="240" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow2_di" bpmnElement="flow2">
        <omgdi:waypoint x="340" y="280" /><omgdi:waypoint x="395" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow3_di" bpmnElement="flow3">
        <omgdi:waypoint x="495" y="280" /><omgdi:waypoint x="555" y="280" />
      </bpmndi:BPMNEdge>
      <!-- managerDecisionGateway: reject → endRejected -->
      <bpmndi:BPMNEdge id="flow4_di" bpmnElement="flow4">
        <omgdi:waypoint x="580" y="305" /><omgdi:waypoint x="580" y="438" /><omgdi:waypoint x="593" y="438" />
      </bpmndi:BPMNEdge>
      <!-- managerDecisionGateway: approve → amountGateway -->
      <bpmndi:BPMNEdge id="flow5_di" bpmnElement="flow5">
        <omgdi:waypoint x="605" y="280" /><omgdi:waypoint x="670" y="280" />
      </bpmndi:BPMNEdge>
      <!-- managerDecisionGateway: escalate → directorApproval -->
      <bpmndi:BPMNEdge id="flow5e_di" bpmnElement="flow5e">
        <omgdi:waypoint x="580" y="255" /><omgdi:waypoint x="580" y="180" /><omgdi:waypoint x="800" y="180" />
      </bpmndi:BPMNEdge>
      <!-- amountGateway: >50k → directorApproval -->
      <bpmndi:BPMNEdge id="flow6_di" bpmnElement="flow6">
        <omgdi:waypoint x="695" y="255" /><omgdi:waypoint x="695" y="180" /><omgdi:waypoint x="800" y="180" />
      </bpmndi:BPMNEdge>
      <!-- amountGateway: <=50k → endApproved (manager-approved, no director needed) -->
      <bpmndi:BPMNEdge id="flow7_di" bpmnElement="flow7">
        <omgdi:waypoint x="720" y="280" /><omgdi:waypoint x="1130" y="280" /><omgdi:waypoint x="1130" y="198" />
      </bpmndi:BPMNEdge>
      <!-- directorApproval → directorDecisionGateway -->
      <bpmndi:BPMNEdge id="flow8_di" bpmnElement="flow8">
        <omgdi:waypoint x="900" y="180" /><omgdi:waypoint x="960" y="180" />
      </bpmndi:BPMNEdge>
      <!-- directorDecisionGateway: approve → endApproved -->
      <bpmndi:BPMNEdge id="flow9_di" bpmnElement="flow9">
        <omgdi:waypoint x="1010" y="180" /><omgdi:waypoint x="1112" y="180" />
      </bpmndi:BPMNEdge>
      <!-- directorDecisionGateway: reject → endRejected -->
      <bpmndi:BPMNEdge id="flow10_di" bpmnElement="flow10">
        <omgdi:waypoint x="985" y="205" /><omgdi:waypoint x="985" y="438" /><omgdi:waypoint x="593" y="438" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
