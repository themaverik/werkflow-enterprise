<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://werkflow.com/bpmn/procurement">

  <!-- ADR-008: cross-process signal — thrown by procurement, caught by asset-request -->
  <signal id="procurementApprovedSignal" name="procurementApproved" flowable:scope="global"/>

  <process id="procurement-approval-process" name="Procurement Approval Process" isExecutable="true"
           flowable:versionTag="2">

    <documentation>Purchase request approval workflow with vendor selection and DMN-backed approval routing.
After calculating total cost, a DMN service task (serviceTask flowable:type="dmn") evaluates the
procurement_matrix decision table to determine the required approval path (DIRECT_PURCHASE,
MANAGER_APPROVAL, COMMITTEE_REVIEW, BOARD_APPROVAL).
An exclusive gateway then routes the request to the appropriate human task. Edit procurement-matrix.dmn
to adjust spend thresholds and category rules — no code changes required.

V2 fixes (2026-05-27):
- procurementRouteGateway gains a default flow so an unknown DMN output fails cleanly (P0).
- DOA tiers corrected: managerApproval=DOA_L2, committeeApproval=DOA_L3, boardApproval=DOA_L4 (DOA inversion fix).
- throwProcurementApproved signal is also thrown on the DIRECT_PURCHASE path so asset-request-process
  never hangs waiting for a signal that was never thrown.
- Missing BPMNShape entries added for throwProcurementApproved and boundary events (DI fix).</documentation>

    <extensionElements>
      <flowable:properties>
        <flowable:property name="category" value="examples"/>
      </flowable:properties>
    </extensionElements>

    <!-- Start Event -->
    <startEvent id="startEvent" name="Purchase Request Submitted" flowable:formKey="procurement-request-form">
      <documentation>Employee submits a purchase request</documentation>
    </startEvent>

    <!-- Step 1: Create Purchase Request in Procurement Service -->
    <serviceTask id="createPurchaseRequest" name="Create Purchase Request"
                 flowable:delegateExpression="${externalApiCallDelegate}">
      <documentation>Creates purchase request record in Procurement Service via REST API</documentation>
      <extensionElements>
        <flowable:field name="connector"><flowable:string>procurement</flowable:string></flowable:field>
        <flowable:field name="path"><flowable:string>/api/workflow/procurement/purchase-requests</flowable:string></flowable:field>
        <flowable:field name="method"><flowable:string>POST</flowable:string></flowable:field>
        <flowable:field name="body"><flowable:string>{"requestId":"${requestId}","itemName":"${itemName}","quantity":${quantity},"estimatedCost":${estimatedCost}}</flowable:string></flowable:field>
        <flowable:field name="extractFields"><flowable:string>purchaseRequestId:$.id</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>
    <boundaryEvent id="errorBoundary_createRequest" attachedToRef="createPurchaseRequest" cancelActivity="true">
      <errorEventDefinition/>
    </boundaryEvent>

    <!-- Step 2: Fetch Approved Vendors -->
    <serviceTask id="fetchVendors" name="Fetch Approved Vendors"
                 flowable:delegateExpression="${externalApiCallDelegate}">
      <documentation>Retrieves list of approved vendors for the requested item category</documentation>
      <extensionElements>
        <flowable:field name="connector"><flowable:string>procurement</flowable:string></flowable:field>
        <flowable:field name="path"><flowable:expression>/api/workflow/procurement/vendors?category=${itemCategory}</flowable:expression></flowable:field>
        <flowable:field name="method"><flowable:string>GET</flowable:string></flowable:field>
        <flowable:field name="extractFields"><flowable:string>vendorList:$.vendors</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Step 3: Select Vendor -->
    <userTask id="selectVendor" name="Select Vendor"
              flowable:candidateGroups="DOA_L1,SUPER_ADMIN"
              flowable:formKey="vendor-selection">
      <documentation>Procurement team selects vendor from approved vendor list</documentation>
    </userTask>

    <!-- Step 4: Request Quotations -->
    <serviceTask id="requestQuotations" name="Request Quotations"
                 flowable:delegateExpression="${externalApiCallDelegate}">
      <documentation>Sends quotation requests to selected vendors</documentation>
      <extensionElements>
        <flowable:field name="connector"><flowable:string>procurement</flowable:string></flowable:field>
        <flowable:field name="path"><flowable:string>/api/workflow/procurement/quotations/request</flowable:string></flowable:field>
        <flowable:field name="method"><flowable:string>POST</flowable:string></flowable:field>
        <flowable:field name="body"><flowable:string>{"purchaseRequestId":"${purchaseRequestId}","vendorIds":${vendorList}}</flowable:string></flowable:field>
        <flowable:field name="extractFields"><flowable:string>quotationIds:$.quotationIds</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Step 5: Review Quotations -->
    <userTask id="reviewQuotations" name="Review Quotations"
              flowable:candidateGroups="DOA_L1,SUPER_ADMIN"
              flowable:formKey="quotation-review">
      <documentation>Procurement team reviews and compares vendor quotations</documentation>
    </userTask>

    <!-- Step 6: Calculate Total Cost -->
    <serviceTask id="calculateTotalCost" name="Calculate Total Cost"
                 flowable:delegateExpression="${externalApiCallDelegate}">
      <documentation>Calculates total cost including taxes and shipping. Sets totalCost and category variables.</documentation>
      <extensionElements>
        <flowable:field name="connector"><flowable:string>procurement</flowable:string></flowable:field>
        <flowable:field name="path"><flowable:expression>/api/workflow/procurement/quotations/${selectedQuotationId}/cost</flowable:expression></flowable:field>
        <flowable:field name="method"><flowable:string>GET</flowable:string></flowable:field>
        <flowable:field name="extractFields"><flowable:string>totalCost:$.totalCost,taxAmount:$.taxAmount,category:$.category</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Step 7: DMN Decision Task — evaluate procurement_matrix DMN. -->
    <!-- Flowable 7.2 evaluates DMN only via serviceTask flowable:type="dmn" with a -->
    <!-- decisionTableReferenceKey field extension (NOT businessRuleTask, which routes to -->
    <!-- the legacy Drools engine and never reaches DMN — see ADR-026 re-audit). -->
    <!-- The decision's output columns (procurementPath, requiresCommittee) are written -->
    <!-- directly as process variables. Edit procurement-matrix.dmn to change thresholds. -->
    <serviceTask id="evaluateProcurement" name="Evaluate Procurement Path" flowable:type="dmn">
      <documentation>Evaluates the procurement approval matrix. Input: amount, category.
Output: procurementPath = DIRECT_PURCHASE | MANAGER_APPROVAL | COMMITTEE_REVIEW | BOARD_APPROVAL.
Also sets requiresCommittee boolean. Thresholds and category rules are defined in procurement-matrix.dmn.</documentation>
      <extensionElements>
        <flowable:field name="decisionTableReferenceKey">
          <flowable:string>procurement_matrix</flowable:string>
        </flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Step 8: Route based on DMN output.
         default flow routes an unrecognised procurementPath to the rejected path so
         a DMN mis-fire fails cleanly instead of leaving the instance hanging. -->
    <exclusiveGateway id="procurementRouteGateway" name="Route by Procurement Path"
                      default="flow_to_rejected_default"/>

    <!-- Branch A: Direct purchase — throw signal first so asset-request never hangs,
         then create the PO. -->
    <sequenceFlow id="flow_to_direct" sourceRef="procurementRouteGateway" targetRef="throwProcurementApproved_direct">
      <conditionExpression xsi:type="tFormalExpression">${procurementPath == 'DIRECT_PURCHASE'}</conditionExpression>
    </sequenceFlow>

    <!-- Branch B: Manager approval -->
    <sequenceFlow id="flow_to_manager" sourceRef="procurementRouteGateway" targetRef="managerApproval">
      <conditionExpression xsi:type="tFormalExpression">${procurementPath == 'MANAGER_APPROVAL'}</conditionExpression>
    </sequenceFlow>

    <!-- Branch C: Committee review -->
    <sequenceFlow id="flow_to_committee" sourceRef="procurementRouteGateway" targetRef="committeeApproval">
      <conditionExpression xsi:type="tFormalExpression">${procurementPath == 'COMMITTEE_REVIEW'}</conditionExpression>
    </sequenceFlow>

    <!-- Branch D: Board approval -->
    <sequenceFlow id="flow_to_board" sourceRef="procurementRouteGateway" targetRef="boardApproval">
      <conditionExpression xsi:type="tFormalExpression">${procurementPath == 'BOARD_APPROVAL'}</conditionExpression>
    </sequenceFlow>

    <!-- Branch DEFAULT: unknown DMN output → reject cleanly (P0 fix) -->
    <sequenceFlow id="flow_to_rejected_default" sourceRef="procurementRouteGateway" targetRef="updateRejected"/>

    <!-- Signal throw on DIRECT_PURCHASE path — ensures asset-request-process is unblocked
         whenever a PO is created, not just on the human-approval approved path. -->
    <intermediateThrowEvent id="throwProcurementApproved_direct" name="Signal: Procurement Approved (Direct)">
      <signalEventDefinition signalRef="procurementApprovedSignal"/>
    </intermediateThrowEvent>
    <sequenceFlow id="flow_direct_signal_to_po" sourceRef="throwProcurementApproved_direct" targetRef="createPurchaseOrder"/>

    <!-- Approval tasks — DOA tiers corrected (V2 fix):
         managerApproval = DOA_L2 (lowest approver tier, correct)
         committeeApproval = DOA_L3 (higher than manager, fixed from DOA_L1)
         boardApproval = DOA_L4 (highest tier, fixed from DOA_L1) -->
    <userTask id="managerApproval" name="Manager Approval"
              flowable:candidateGroups="DOA_L2,SUPER_ADMIN"
              flowable:formKey="procurement-approval">
      <documentation>Manager reviews mid-range procurement requests. Sets decision = approve or reject.</documentation>
    </userTask>
    <!-- PT48H non-interrupting reminder -->
    <boundaryEvent id="timerReminder_manager" attachedToRef="managerApproval" cancelActivity="false">
      <timerEventDefinition><timeDuration>PT48H</timeDuration></timerEventDefinition>
    </boundaryEvent>
    <!-- PT72H interrupting escalation -->
    <boundaryEvent id="timerEscalate_manager" attachedToRef="managerApproval" cancelActivity="true">
      <timerEventDefinition><timeDuration>PT72H</timeDuration></timerEventDefinition>
    </boundaryEvent>

    <userTask id="committeeApproval" name="Committee Approval"
              flowable:candidateGroups="DOA_L3,SUPER_ADMIN"
              flowable:formKey="procurement-approval">
      <documentation>Procurement committee reviews high-value requests. Sets decision = approve or reject.</documentation>
    </userTask>
    <boundaryEvent id="timerReminder_committee" attachedToRef="committeeApproval" cancelActivity="false">
      <timerEventDefinition><timeDuration>PT48H</timeDuration></timerEventDefinition>
    </boundaryEvent>
    <boundaryEvent id="timerEscalate_committee" attachedToRef="committeeApproval" cancelActivity="true">
      <timerEventDefinition><timeDuration>PT72H</timeDuration></timerEventDefinition>
    </boundaryEvent>

    <userTask id="boardApproval" name="Board Approval"
              flowable:candidateGroups="DOA_L4,SUPER_ADMIN"
              flowable:formKey="procurement-approval">
      <documentation>Board reviews large IT/infrastructure spend. Sets decision = approve or reject.</documentation>
    </userTask>
    <boundaryEvent id="timerReminder_board" attachedToRef="boardApproval" cancelActivity="false">
      <timerEventDefinition><timeDuration>PT48H</timeDuration></timerEventDefinition>
    </boundaryEvent>
    <boundaryEvent id="timerEscalate_board" attachedToRef="boardApproval" cancelActivity="true">
      <timerEventDefinition><timeDuration>PT72H</timeDuration></timerEventDefinition>
    </boundaryEvent>

    <!-- All human approval paths converge here -->
    <exclusiveGateway id="approvalJoin" name="Approval Complete"/>

    <sequenceFlow id="flow_manager_join"   sourceRef="managerApproval"   targetRef="approvalJoin"/>
    <sequenceFlow id="flow_committee_join" sourceRef="committeeApproval" targetRef="approvalJoin"/>
    <sequenceFlow id="flow_board_join"     sourceRef="boardApproval"     targetRef="approvalJoin"/>

    <!-- Final decision gateway after human approval -->
    <exclusiveGateway id="approvalDecisionGateway" name="Approved?"/>

    <sequenceFlow id="flow_join_decision" sourceRef="approvalJoin" targetRef="approvalDecisionGateway"/>

    <!-- Human-approval approved path: throw signal then create PO -->
    <sequenceFlow id="approved" sourceRef="approvalDecisionGateway" targetRef="throwProcurementApproved">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'approve'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="rejected" sourceRef="approvalDecisionGateway" targetRef="updateRejected">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'reject'}</conditionExpression>
    </sequenceFlow>

    <!-- M5: Signal throw after human-approval approved path — ADR-008 -->
    <intermediateThrowEvent id="throwProcurementApproved" name="Signal: Procurement Approved">
      <signalEventDefinition signalRef="procurementApprovedSignal"/>
    </intermediateThrowEvent>
    <sequenceFlow id="flow_signal_to_po" sourceRef="throwProcurementApproved" targetRef="createPurchaseOrder"/>

    <!-- Timer reminder tasks (non-interrupting PT48H) -->
    <serviceTask id="sendReminderNotification" name="Send Approval Reminder"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${notificationDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>approval-reminder</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>
    <endEvent id="endReminder" name="Reminder Sent"/>

    <!-- Timer escalation tasks (interrupting PT72H) -->
    <serviceTask id="sendEscalationNotification" name="Send Escalation Notice"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${notificationDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>approval-escalation</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>SUPER_ADMIN</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>
    <endEvent id="endEscalated" name="Escalated"/>

    <!-- Approval path: create and send purchase order (shared by both direct and human-approval paths) -->
    <serviceTask id="createPurchaseOrder" name="Create Purchase Order"
                 flowable:delegateExpression="${externalApiCallDelegate}">
      <documentation>Creates purchase order in Procurement Service</documentation>
      <extensionElements>
        <flowable:field name="connector"><flowable:string>procurement</flowable:string></flowable:field>
        <flowable:field name="path"><flowable:string>/api/workflow/procurement/purchase-orders</flowable:string></flowable:field>
        <flowable:field name="method"><flowable:string>POST</flowable:string></flowable:field>
        <flowable:field name="body"><flowable:string>{"requestId":"${requestId}","selectedQuotationId":"${selectedQuotationId}"}</flowable:string></flowable:field>
        <flowable:field name="extractFields"><flowable:string>poNumber:$.poNumber</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>
    <boundaryEvent id="errorBoundary_createPO" attachedToRef="createPurchaseOrder" cancelActivity="true">
      <errorEventDefinition/>
    </boundaryEvent>

    <serviceTask id="sendPOToVendor" name="Send PO to Vendor"
                 flowable:delegateExpression="${externalApiCallDelegate}">
      <documentation>Sends purchase order to selected vendor via email</documentation>
      <extensionElements>
        <flowable:field name="connector"><flowable:string>procurement</flowable:string></flowable:field>
        <flowable:field name="path"><flowable:expression>/api/workflow/procurement/purchase-orders/${poNumber}/send</flowable:expression></flowable:field>
        <flowable:field name="method"><flowable:string>POST</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>
    <boundaryEvent id="errorBoundary_sendPO" attachedToRef="sendPOToVendor" cancelActivity="true">
      <errorEventDefinition/>
    </boundaryEvent>

    <serviceTask id="updateApproved" name="Update Status: Approved"
                 flowable:delegateExpression="${externalApiCallDelegate}">
      <extensionElements>
        <flowable:field name="connector"><flowable:string>procurement</flowable:string></flowable:field>
        <flowable:field name="path"><flowable:expression>/api/workflow/procurement/purchase-requests/${requestId}/approve</flowable:expression></flowable:field>
        <flowable:field name="method"><flowable:string>PUT</flowable:string></flowable:field>
        <flowable:field name="body"><flowable:string>{"poNumber":"${poNumber}"}</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <serviceTask id="sendApprovalNotification" name="Send Approval Notification"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${notificationDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>${initiator}</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>procurement-approved</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Rejection path -->
    <serviceTask id="updateRejected" name="Update Status: Rejected"
                 flowable:delegateExpression="${externalApiCallDelegate}">
      <extensionElements>
        <flowable:field name="connector"><flowable:string>procurement</flowable:string></flowable:field>
        <flowable:field name="path"><flowable:expression>/api/workflow/procurement/purchase-requests/${requestId}/reject</flowable:expression></flowable:field>
        <flowable:field name="method"><flowable:string>PUT</flowable:string></flowable:field>
        <flowable:field name="body"><flowable:string>{"rejectionReason":"${rejectionReason}"}</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <serviceTask id="sendRejectionNotification" name="Send Rejection Notification"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${notificationDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>${initiator}</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>procurement-rejected</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- End Events -->
    <endEvent id="endEventApproved" name="PO Created"/>
    <endEvent id="endEventRejected" name="Request Rejected"/>

    <!-- Sequence Flows: initial pipeline -->
    <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="createPurchaseRequest"/>
    <sequenceFlow id="flow2" sourceRef="createPurchaseRequest" targetRef="fetchVendors"/>
    <sequenceFlow id="flow3" sourceRef="fetchVendors" targetRef="selectVendor"/>
    <sequenceFlow id="flow4" sourceRef="selectVendor" targetRef="requestQuotations"/>
    <sequenceFlow id="flow5" sourceRef="requestQuotations" targetRef="reviewQuotations"/>
    <sequenceFlow id="flow6" sourceRef="reviewQuotations" targetRef="calculateTotalCost"/>
    <sequenceFlow id="flow7" sourceRef="calculateTotalCost" targetRef="evaluateProcurement"/>
    <sequenceFlow id="flow8" sourceRef="evaluateProcurement" targetRef="procurementRouteGateway"/>

    <!-- Sequence Flows: approved path -->
    <sequenceFlow id="flow9"  sourceRef="createPurchaseOrder"      targetRef="sendPOToVendor"/>
    <sequenceFlow id="flow10" sourceRef="sendPOToVendor"           targetRef="updateApproved"/>
    <sequenceFlow id="flow11" sourceRef="updateApproved"           targetRef="sendApprovalNotification"/>
    <sequenceFlow id="flow12" sourceRef="sendApprovalNotification" targetRef="endEventApproved"/>

    <!-- Sequence Flows: rejection path -->
    <sequenceFlow id="flow13" sourceRef="updateRejected"           targetRef="sendRejectionNotification"/>
    <sequenceFlow id="flow14" sourceRef="sendRejectionNotification" targetRef="endEventRejected"/>

    <!-- Timer reminder flows (non-interrupting PT48H — same notification task, shared) -->
    <sequenceFlow id="flow_reminder_manager"   sourceRef="timerReminder_manager"   targetRef="sendReminderNotification"/>
    <sequenceFlow id="flow_reminder_committee" sourceRef="timerReminder_committee" targetRef="sendReminderNotification"/>
    <sequenceFlow id="flow_reminder_board"     sourceRef="timerReminder_board"     targetRef="sendReminderNotification"/>
    <sequenceFlow id="flow_reminder_end"       sourceRef="sendReminderNotification" targetRef="endReminder"/>

    <!-- Timer escalation flows (interrupting PT72H) -->
    <sequenceFlow id="flow_escalate_manager"   sourceRef="timerEscalate_manager"   targetRef="sendEscalationNotification"/>
    <sequenceFlow id="flow_escalate_committee" sourceRef="timerEscalate_committee" targetRef="sendEscalationNotification"/>
    <sequenceFlow id="flow_escalate_board"     sourceRef="timerEscalate_board"     targetRef="sendEscalationNotification"/>
    <sequenceFlow id="flow_escalate_end"       sourceRef="sendEscalationNotification" targetRef="endEscalated"/>

    <!-- Error boundary flows — service task failures notify and terminate -->
    <serviceTask id="notifyServiceError" name="Notify Service Error"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${notificationDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>process-error</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>SUPER_ADMIN</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>
    <endEvent id="endServiceError" name="Process Error"/>

    <sequenceFlow id="flow_error_createRequest" sourceRef="errorBoundary_createRequest" targetRef="notifyServiceError"/>
    <sequenceFlow id="flow_error_createPO"      sourceRef="errorBoundary_createPO"      targetRef="notifyServiceError"/>
    <sequenceFlow id="flow_error_sendPO"        sourceRef="errorBoundary_sendPO"        targetRef="notifyServiceError"/>
    <sequenceFlow id="flow_error_end"           sourceRef="notifyServiceError"          targetRef="endServiceError"/>

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_procurement-approval-process">
    <bpmndi:BPMNPlane bpmnElement="procurement-approval-process" id="BPMNPlane_procurement">

      <!-- Start -->
      <bpmndi:BPMNShape bpmnElement="startEvent" id="BPMNShape_startEvent">
        <omgdc:Bounds x="100" y="302" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="73" y="345" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="createPurchaseRequest" id="BPMNShape_createPurchaseRequest">
        <omgdc:Bounds x="186" y="280" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="fetchVendors" id="BPMNShape_fetchVendors">
        <omgdc:Bounds x="366" y="280" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="selectVendor" id="BPMNShape_selectVendor">
        <omgdc:Bounds x="546" y="280" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="requestQuotations" id="BPMNShape_requestQuotations">
        <omgdc:Bounds x="726" y="280" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="reviewQuotations" id="BPMNShape_reviewQuotations">
        <omgdc:Bounds x="906" y="280" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="calculateTotalCost" id="BPMNShape_calculateTotalCost">
        <omgdc:Bounds x="1086" y="280" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="evaluateProcurement" id="BPMNShape_evaluateProcurement">
        <omgdc:Bounds x="1266" y="280" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="procurementRouteGateway" id="BPMNShape_procurementRouteGateway" isMarkerVisible="true">
        <omgdc:Bounds x="1456" y="295" width="50" height="50"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="1420" y="352" width="122" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Direct purchase: signal throw then PO -->
      <bpmndi:BPMNShape bpmnElement="throwProcurementApproved_direct" id="BPMNShape_throwProcurementApproved_direct">
        <omgdc:Bounds x="1576" y="62" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="1550" y="38" width="88" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Approval task shapes: 3 vertical lanes -->
      <bpmndi:BPMNShape bpmnElement="managerApproval" id="BPMNShape_managerApproval">
        <omgdc:Bounds x="1576" y="160" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="committeeApproval" id="BPMNShape_committeeApproval">
        <omgdc:Bounds x="1576" y="280" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="boardApproval" id="BPMNShape_boardApproval">
        <omgdc:Bounds x="1576" y="400" width="120" height="80"/>
