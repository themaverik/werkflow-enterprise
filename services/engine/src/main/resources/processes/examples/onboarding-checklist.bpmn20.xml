<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://werkflow.com/bpmn/examples">

  <process id="onboarding-checklist" name="Onboarding Checklist" isExecutable="true">

    <documentation>Employee onboarding workflow. HR submits the new hire details; IT and Facilities tasks run in parallel; once both are complete a manager assigns a buddy. Demonstrates parallel gateway usage. Engine-internal — no external API calls.</documentation>

    <!-- Start -->
    <startEvent id="startEvent" name="Onboarding Started" flowable:initiator="initiator" />

    <!-- Step 1: HR fills in new hire details -->
    <userTask id="hrSubmit" name="HR: Submit Onboarding"
              flowable:candidateGroups="SUPER_ADMIN"
              flowable:formKey="onboarding-checklist-form">
      <documentation>HR provides new hire name, email, department, start date, and equipment needs</documentation>
    </userTask>

    <!-- Parallel fork: IT and Facilities work happens simultaneously -->
    <parallelGateway id="forkGateway" name="Start Parallel Setup" />

    <!-- Branch A: IT provisions equipment and system access -->
    <userTask id="itSetup" name="IT: System Setup"
              flowable:candidateGroups="SUPER_ADMIN">
      <documentation>IT sets up laptop, email account, system access, and any equipment listed in equipmentNeeded</documentation>
    </userTask>

    <!-- Branch B: Facilities arranges workspace -->
    <userTask id="facilitiesSetup" name="Facilities: Workspace Setup"
              flowable:candidateGroups="SUPER_ADMIN">
      <documentation>Facilities assigns desk, access card, and prepares the workspace</documentation>
    </userTask>

    <!-- Parallel join: both branches must complete before continuing -->
    <parallelGateway id="joinGateway" name="Setup Complete" />

    <!-- Step 2: Manager assigns a buddy (only if buddyRequired == true) -->
    <userTask id="assignBuddy" name="Assign Manager Buddy"
              flowable:candidateGroups="SUPER_ADMIN">
      <documentation>Manager assigns a buddy to guide the new hire through their first weeks</documentation>
    </userTask>

    <!-- Final notification: welcome email to new hire -->
    <serviceTask id="sendWelcomeEmail" name="Send Welcome Email"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${emailActionDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>${employeeEmail}</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>onboarding-complete</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <endEvent id="endEvent" name="Onboarding Complete" />

    <!-- Sequence flows -->
    <sequenceFlow id="flow1" sourceRef="startEvent"       targetRef="hrSubmit" />
    <sequenceFlow id="flow2" sourceRef="hrSubmit"         targetRef="forkGateway" />
    <sequenceFlow id="flow3" sourceRef="forkGateway"      targetRef="itSetup" />
    <sequenceFlow id="flow4" sourceRef="forkGateway"      targetRef="facilitiesSetup" />
    <sequenceFlow id="flow5" sourceRef="itSetup"          targetRef="joinGateway" />
    <sequenceFlow id="flow6" sourceRef="facilitiesSetup"  targetRef="joinGateway" />
    <sequenceFlow id="flow7" sourceRef="joinGateway"      targetRef="assignBuddy" />
    <sequenceFlow id="flow8" sourceRef="assignBuddy"      targetRef="sendWelcomeEmail" />
    <sequenceFlow id="flow9" sourceRef="sendWelcomeEmail" targetRef="endEvent" />

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_onboarding-checklist">
    <bpmndi:BPMNPlane id="BPMNPlane_onboarding-checklist" bpmnElement="onboarding-checklist">

      <bpmndi:BPMNShape id="startEvent_di" bpmnElement="startEvent">
        <omgdc:Bounds x="152" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="126" y="305" width="88" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="hrSubmit_di" bpmnElement="hrSubmit">
        <omgdc:Bounds x="240" y="240" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="forkGateway_di" bpmnElement="forkGateway">
        <omgdc:Bounds x="400" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="372" y="312" width="106" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="itSetup_di" bpmnElement="itSetup">
        <omgdc:Bounds x="510" y="160" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="facilitiesSetup_di" bpmnElement="facilitiesSetup">
        <omgdc:Bounds x="510" y="320" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="joinGateway_di" bpmnElement="joinGateway">
        <omgdc:Bounds x="675" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="655" y="312" width="90" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="assignBuddy_di" bpmnElement="assignBuddy">
        <omgdc:Bounds x="785" y="240" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="sendWelcomeEmail_di" bpmnElement="sendWelcomeEmail">
        <omgdc:Bounds x="945" y="240" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="endEvent_di" bpmnElement="endEvent">
        <omgdc:Bounds x="1107" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="1082" y="305" width="86" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="flow1_di" bpmnElement="flow1">
        <omgdi:waypoint x="188" y="280" /><omgdi:waypoint x="240" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow2_di" bpmnElement="flow2">
        <omgdi:waypoint x="340" y="280" /><omgdi:waypoint x="400" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow3_di" bpmnElement="flow3">
        <omgdi:waypoint x="425" y="255" /><omgdi:waypoint x="425" y="200" /><omgdi:waypoint x="510" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow4_di" bpmnElement="flow4">
        <omgdi:waypoint x="425" y="305" /><omgdi:waypoint x="425" y="360" /><omgdi:waypoint x="510" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow5_di" bpmnElement="flow5">
        <omgdi:waypoint x="610" y="200" /><omgdi:waypoint x="700" y="200" /><omgdi:waypoint x="700" y="255" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow6_di" bpmnElement="flow6">
        <omgdi:waypoint x="610" y="360" /><omgdi:waypoint x="700" y="360" /><omgdi:waypoint x="700" y="305" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow7_di" bpmnElement="flow7">
        <omgdi:waypoint x="725" y="280" /><omgdi:waypoint x="785" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow8_di" bpmnElement="flow8">
        <omgdi:waypoint x="885" y="280" /><omgdi:waypoint x="945" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow9_di" bpmnElement="flow9">
        <omgdi:waypoint x="1045" y="280" /><omgdi:waypoint x="1107" y="280" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
