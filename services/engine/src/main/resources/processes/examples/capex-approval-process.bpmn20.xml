        <omgdc:Bounds x="1450" y="330" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endEventApproved_di" bpmnElement="endEventApproved">
