<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://werkflow.com/bpmn/examples">

  <process id="parallel-committee-approval" name="Parallel Committee Approval" isExecutable="true">

    <documentation>Demonstrates Parallel Gateway and concurrent user task execution. A proposal is submitted
and then reviewed simultaneously by three committee members. All three must complete before
the process advances. Useful for board approvals, multi-stakeholder sign-offs, or panel reviews.</documentation>

    <!-- Start: submitter creates the proposal -->
    <startEvent id="committeeStart" name="Proposal Submitted" flowable:initiator="initiator">
    </startEvent>

    <sequenceFlow id="flow_start_submit" sourceRef="committeeStart" targetRef="submitProposal"/>

    <!-- Step 1: submitter fills in the proposal form -->
    <userTask id="submitProposal" name="Submit Proposal"
              flowable:assignee="${initiator}"
              flowable:formKey="committee-review-start">
      <documentation>Submitter provides proposal title, description, and supporting documents.</documentation>
    </userTask>

    <sequenceFlow id="flow_submit_fork" sourceRef="submitProposal" targetRef="committeeFork"/>

    <!-- Parallel fork: all three committee reviews start at the same time -->
    <parallelGateway id="committeeFork" name="Start Committee Review"/>

    <sequenceFlow id="flow_fork_member1" sourceRef="committeeFork" targetRef="member1Review"/>
    <sequenceFlow id="flow_fork_member2" sourceRef="committeeFork" targetRef="member2Review"/>
    <sequenceFlow id="flow_fork_member3" sourceRef="committeeFork" targetRef="member3Review"/>

    <!-- Committee Member 1 -->
    <userTask id="member1Review" name="Committee Member 1 Review"
              flowable:candidateGroups="committee_member,ADMIN"
              flowable:formKey="committee-review-decision">
      <documentation>First committee member casts their vote.</documentation>
    </userTask>

    <!-- Committee Member 2 -->
    <userTask id="member2Review" name="Committee Member 2 Review"
              flowable:candidateGroups="committee_member,ADMIN"
              flowable:formKey="committee-review-decision">
      <documentation>Second committee member casts their vote.</documentation>
    </userTask>

    <!-- Committee Member 3 -->
    <userTask id="member3Review" name="Committee Member 3 Review"
              flowable:candidateGroups="committee_member,ADMIN"
              flowable:formKey="committee-review-decision">
      <documentation>Third committee member casts their vote.</documentation>
    </userTask>

    <sequenceFlow id="flow_member1_join" sourceRef="member1Review" targetRef="committeeJoin"/>
    <sequenceFlow id="flow_member2_join" sourceRef="member2Review" targetRef="committeeJoin"/>
    <sequenceFlow id="flow_member3_join" sourceRef="member3Review" targetRef="committeeJoin"/>

    <!-- Parallel join: waits for all three reviews -->
    <parallelGateway id="committeeJoin" name="All Reviews Complete"/>

    <sequenceFlow id="flow_join_notify" sourceRef="committeeJoin" targetRef="sendApprovalNotice"/>

    <!-- Notify submitter of outcome -->
    <serviceTask id="sendApprovalNotice" name="Send Outcome Notification"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${emailActionDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>${initiator}</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>committee-outcome</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <sequenceFlow id="flow_notify_end" sourceRef="sendApprovalNotice" targetRef="committeeEnd"/>

    <endEvent id="committeeEnd" name="Committee Review Complete"/>

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_parallel-committee">
    <bpmndi:BPMNPlane id="BPMNPlane_parallel-committee" bpmnElement="parallel-committee-approval">

      <!-- Start -->
      <bpmndi:BPMNShape id="committeeStart_di" bpmnElement="committeeStart">
        <omgdc:Bounds x="152" y="272" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="127" y="315" width="86" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Submit Proposal task -->
      <bpmndi:BPMNShape id="submitProposal_di" bpmnElement="submitProposal">
        <omgdc:Bounds x="240" y="250" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- Fork gateway -->
      <bpmndi:BPMNShape id="committeeFork_di" bpmnElement="committeeFork" isMarkerVisible="false">
        <omgdc:Bounds x="415" y="265" width="50" height="50"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="395" y="322" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Member 1 Review -->
      <bpmndi:BPMNShape id="member1Review_di" bpmnElement="member1Review">
        <omgdc:Bounds x="530" y="130" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- Member 2 Review -->
      <bpmndi:BPMNShape id="member2Review_di" bpmnElement="member2Review">
        <omgdc:Bounds x="530" y="250" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- Member 3 Review -->
      <bpmndi:BPMNShape id="member3Review_di" bpmnElement="member3Review">
        <omgdc:Bounds x="530" y="370" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- Join gateway -->
      <bpmndi:BPMNShape id="committeeJoin_di" bpmnElement="committeeJoin" isMarkerVisible="false">
        <omgdc:Bounds x="715" y="265" width="50" height="50"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="695" y="322" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Send Outcome Notification -->
      <bpmndi:BPMNShape id="sendApprovalNotice_di" bpmnElement="sendApprovalNotice">
        <omgdc:Bounds x="830" y="250" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- End -->
      <bpmndi:BPMNShape id="committeeEnd_di" bpmnElement="committeeEnd">
        <omgdc:Bounds x="1012" y="272" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="985" y="315" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Sequence flow edges -->
      <bpmndi:BPMNEdge id="flow_start_submit_di" bpmnElement="flow_start_submit">
        <omgdi:waypoint x="188" y="290"/>
        <omgdi:waypoint x="240" y="290"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_submit_fork_di" bpmnElement="flow_submit_fork">
        <omgdi:waypoint x="360" y="290"/>
        <omgdi:waypoint x="415" y="290"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_fork_member1_di" bpmnElement="flow_fork_member1">
        <omgdi:waypoint x="440" y="265"/>
        <omgdi:waypoint x="440" y="170"/>
        <omgdi:waypoint x="530" y="170"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_fork_member2_di" bpmnElement="flow_fork_member2">
        <omgdi:waypoint x="465" y="290"/>
        <omgdi:waypoint x="530" y="290"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_fork_member3_di" bpmnElement="flow_fork_member3">
        <omgdi:waypoint x="440" y="315"/>
        <omgdi:waypoint x="440" y="410"/>
        <omgdi:waypoint x="530" y="410"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_member1_join_di" bpmnElement="flow_member1_join">
        <omgdi:waypoint x="650" y="170"/>
        <omgdi:waypoint x="740" y="170"/>
        <omgdi:waypoint x="740" y="265"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_member2_join_di" bpmnElement="flow_member2_join">
        <omgdi:waypoint x="650" y="290"/>
        <omgdi:waypoint x="715" y="290"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_member3_join_di" bpmnElement="flow_member3_join">
        <omgdi:waypoint x="650" y="410"/>
        <omgdi:waypoint x="740" y="410"/>
        <omgdi:waypoint x="740" y="315"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_join_notify_di" bpmnElement="flow_join_notify">
        <omgdi:waypoint x="765" y="290"/>
        <omgdi:waypoint x="830" y="290"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_notify_end_di" bpmnElement="flow_notify_end">
        <omgdi:waypoint x="950" y="290"/>
        <omgdi:waypoint x="1012" y="290"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
