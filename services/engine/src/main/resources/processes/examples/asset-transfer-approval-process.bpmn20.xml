      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="createTransferRecord" id="BPMNShape_createTransferRecord">
        <omgdc:Bounds height="80.0" width="100.0" x="1830.0" y="138.0"/>
