<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="leave_approval_definitions"
             name="Leave Approval Definitions"
             namespace="http://werkflow.com/dmn">

  <decision id="leave_approval" name="Leave Approval Rules">
    <description>Determines whether a leave request requires formal approval and which
role must approve it, based on duration and leave type. Short casual leave is
auto-approved; longer or special-category leave escalates to manager or HR.</description>
    <decisionTable id="leave_approval_table" hitPolicy="FIRST">

      <input id="input_days" label="Leave Days">
        <inputExpression id="input_days_expr" typeRef="number">
          <text>leaveDays</text>
        </inputExpression>
      </input>

      <input id="input_type" label="Leave Type">
        <inputExpression id="input_type_expr" typeRef="string">
          <text>leaveType</text>
        </inputExpression>
      </input>

      <output id="output_required" label="Approval Required" name="approvalRequired" typeRef="boolean"/>
      <output id="output_approver" label="Approver Role" name="approverRole" typeRef="string"/>

      <!-- Flowable evaluates input entries as JUEL, not FEEL: comma "one-of" lists
           ("MEDICAL","MATERNITY","PATERNITY") and FEEL ranges ([4..10], [1..3]) are
           invalid. One-of lists are split into single-equality rules; ranges become
           one-sided bounds whose upper limit is implicit under FIRST hit policy + rule
           order. Behaviour-equivalent to the original FEEL intent. -->

      <!-- Rule 1a–1c: Medical / Maternity / Paternity always require HR (any duration) -->
      <rule id="rule_hr_medical">
        <description>Medical leave always requires HR regardless of duration</description>
        <inputEntry id="rule_hr_med_days"><text></text></inputEntry>
        <inputEntry id="rule_hr_med_type"><text>== "MEDICAL"</text></inputEntry>
        <outputEntry id="rule_hr_med_req"><text>true</text></outputEntry>
        <outputEntry id="rule_hr_med_approver"><text>"HR_MANAGER"</text></outputEntry>
      </rule>
      <rule id="rule_hr_maternity">
        <description>Maternity leave always requires HR regardless of duration</description>
        <inputEntry id="rule_hr_mat_days"><text></text></inputEntry>
        <inputEntry id="rule_hr_mat_type"><text>== "MATERNITY"</text></inputEntry>
        <outputEntry id="rule_hr_mat_req"><text>true</text></outputEntry>
        <outputEntry id="rule_hr_mat_approver"><text>"HR_MANAGER"</text></outputEntry>
      </rule>
      <rule id="rule_hr_paternity">
        <description>Paternity leave always requires HR regardless of duration</description>
        <inputEntry id="rule_hr_pat_days"><text></text></inputEntry>
        <inputEntry id="rule_hr_pat_type"><text>== "PATERNITY"</text></inputEntry>
        <outputEntry id="rule_hr_pat_req"><text>true</text></outputEntry>
        <outputEntry id="rule_hr_pat_approver"><text>"HR_MANAGER"</text></outputEntry>
      </rule>

      <!-- Rule 2: > 10 days any type — HR approval -->
      <rule id="rule_long_leave">
        <description>Leaves longer than 10 days require HR manager approval</description>
        <inputEntry id="rule_long_days"><text>&gt; 10</text></inputEntry>
        <inputEntry id="rule_long_type"><text></text></inputEntry>
        <outputEntry id="rule_long_req"><text>true</text></outputEntry>
        <outputEntry id="rule_long_approver"><text>"HR_MANAGER"</text></outputEntry>
      </rule>

      <!-- Rule 3: 4–10 days — manager approval. Upper bound (<= 10) implicit: rule_long
           (> 10) above matched-and-stopped for longer durations under FIRST hit policy. -->
      <rule id="rule_medium_leave">
        <description>Medium-duration leave requires line manager approval</description>
        <inputEntry id="rule_med_days"><text>&gt;= 4</text></inputEntry>
        <inputEntry id="rule_med_type"><text></text></inputEntry>
        <outputEntry id="rule_med_req"><text>true</text></outputEntry>
        <outputEntry id="rule_med_approver"><text>"LINE_MANAGER"</text></outputEntry>
      </rule>

      <!-- Rule 4a–4b: 1–3 days casual/annual — auto-approved. Upper bound (<= 3) implicit:
           rule_medium (>= 4, any type) above matched-and-stopped for 4+ days. -->
      <rule id="rule_casual_casual">
        <description>Short casual leave is auto-approved with no human approver</description>
        <inputEntry id="rule_cas_cas_days"><text>&gt;= 1</text></inputEntry>
        <inputEntry id="rule_cas_cas_type"><text>== "CASUAL"</text></inputEntry>
        <outputEntry id="rule_cas_cas_req"><text>false</text></outputEntry>
        <outputEntry id="rule_cas_cas_approver"><text>"AUTO"</text></outputEntry>
      </rule>
      <rule id="rule_casual_annual">
        <description>Short annual leave is auto-approved with no human approver</description>
        <inputEntry id="rule_cas_ann_days"><text>&gt;= 1</text></inputEntry>
        <inputEntry id="rule_cas_ann_type"><text>== "ANNUAL"</text></inputEntry>
        <outputEntry id="rule_cas_ann_req"><text>false</text></outputEntry>
        <outputEntry id="rule_cas_ann_approver"><text>"AUTO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
