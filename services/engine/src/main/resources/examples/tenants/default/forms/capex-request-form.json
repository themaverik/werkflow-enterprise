{
  "id": "capex-request-form",
  "name": "CapEx Request Form",
  "type": "default",
  "components": [
    {
      "type": "text",
      "text": "<h3>Capital Expenditure Request Form</h3><p>Please provide details for your CapEx request.</p>"
    },
    {
      "type": "textfield",
      "key": "requestTitle",
      "label": "Request Title",
      "placeholder": "Enter request title",
      "validate": {
        "required": true,
        "minLength": 5,
        "maxLength": 100
      }
    },
    {
      "type": "select",
      "key": "category",
      "label": "Category",
      "values": [
        { "label": "Equipment", "value": "equipment" },
        { "label": "Software", "value": "software" },
        { "label": "Infrastructure", "value": "infrastructure" },
        { "label": "Facility", "value": "facility" },
        { "label": "Other", "value": "other" }
      ],
      "validate": {
        "required": true
      }
    },
    {
      "type": "number",
      "key": "requestAmount",
      "label": "Request Amount (USD)",
      "placeholder": "Enter amount",
      "validate": {
        "required": true,
        "min": 1,
        "max": 10000000
      }
    },
    {
      "type": "textfield",
      "key": "capexOwner",
      "label": "Department",
      "placeholder": "Enter department code (e.g. FIN, OPS, HR)",
      "validate": {
        "required": true
      }
    },
    {
      "type": "textarea",
      "key": "description",
      "label": "Description",
      "placeholder": "Describe the expenditure in detail",
      "validate": {
        "required": true,
        "minLength": 20,
        "maxLength": 2000
      }
    },
    {
      "type": "textarea",
      "key": "businessJustification",
      "label": "Business Justification",
      "placeholder": "Explain why this expenditure is necessary",
      "validate": {
        "required": true,
        "minLength": 50,
        "maxLength": 2000
      }
    },
    {
      "type": "select",
      "key": "priority",
      "label": "Priority",
      "values": [
        { "label": "Low", "value": "low" },
        { "label": "Medium", "value": "medium" },
        { "label": "High", "value": "high" },
        { "label": "Critical", "value": "critical" }
      ],
      "validate": {
        "required": true
      }
    },
    {
      "type": "datetime",
      "subtype": "date",
      "key": "requiredByDate",
      "dateLabel": "Required By Date",
      "validate": {
        "required": true
      }
    },
    {
      "type": "select",
      "key": "slaDuration",
      "label": "SLA Duration (testing)",
      "description": "Testing knob: time before each DOA-level approval SLA timer fires. Leave as the default unless you are exercising the SLA-breach scenario.",
      "defaultValue": "PT15M",
      "values": [
        { "label": "Default (15 min)", "value": "PT15M" },
        { "label": "2 minutes", "value": "PT2M" },
        { "label": "5 minutes", "value": "PT5M" },
        { "label": "10 minutes", "value": "PT10M" },
        { "label": "1 hour", "value": "PT1H" },
        { "label": "1 day", "value": "P1D" }
      ],
      "validate": {
        "required": true
      }
    }
  ]
}
