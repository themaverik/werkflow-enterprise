<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://werkflow.com/bpmn/capex">

  <process id="capex-approval-process" name="Capital Expenditure Approval" isExecutable="true"
           flowable:versionTag="3">

    <documentation>Capital Expenditure approval workflow — V4 DMN-resolved approver groups (ADR-029 Phase 2).
    A DMN service task before each user task evaluates capex-approver-resolution.dmn to set the
    approverGroup process variable. candidateGroups uses ${approverGroup} instead of hardcoded
    DEPT:FIN::DOA:L{n} compound strings. Each approval level has its own decision gateway
    (approve/reject/escalate), fixing the last-write-wins defect from V2 and enabling early-exit
    on reject (ADR-027). CFO is the top level; no escalate route from CFO.</documentation>

    <extensionElements>
      <flowable:properties>
        <flowable:property name="category" value="examples"/>
      </flowable:properties>
    </extensionElements>

    <!-- Start Event -->
    <startEvent id="startEvent" name="CapEx Request Submitted" flowable:formKey="capex-request-form">
      <documentation>Employee submits a capital expenditure request. Required form fields:
requestAmount (number), category (string), capexOwner (string — department code, e.g. FIN).</documentation>
    </startEvent>

    <!-- Action Block: Create CapEx Request via external API -->
    <serviceTask id="createCapExRequest" name="Create CapEx Request"
                 flowable:actionType="EXTERNAL_API_CALL"
                 flowable:delegateExpression="${externalApiCallDelegate}">
      <extensionElements>
        <flowable:field name="connector"><flowable:string>capex-service</flowable:string></flowable:field>
        <flowable:field name="path"><flowable:string>/api/capex-requests</flowable:string></flowable:field>
        <flowable:field name="method"><flowable:string>POST</flowable:string></flowable:field>
        <flowable:field name="responseVariable"><flowable:string>createResponse</flowable:string></flowable:field>
        <flowable:field name="extractFields"><flowable:string>capexRequestId:$.id,capexStatus:$.status</flowable:string></flowable:field>
        <flowable:field name="onError"><flowable:string>FAIL</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Action Block: Check Budget via external API -->
    <serviceTask id="checkBudget" name="Check Budget Availability"
                 flowable:actionType="EXTERNAL_API_CALL"
                 flowable:delegateExpression="${externalApiCallDelegate}">
      <extensionElements>
        <flowable:field name="connector"><flowable:string>capex-service</flowable:string></flowable:field>
        <flowable:field name="path"><flowable:string>/api/budget/check?amount=${requestAmount}&amp;category=${category}</flowable:string></flowable:field>
        <flowable:field name="method"><flowable:string>GET</flowable:string></flowable:field>
        <flowable:field name="responseVariable"><flowable:string>budgetCheck</flowable:string></flowable:field>
        <flowable:field name="extractFields"><flowable:string>budgetAvailable:$.available,availableAmount:$.availableAmount</flowable:string></flowable:field>
        <flowable:field name="onError"><flowable:string>THROW_BPMN_ERROR</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Budget precondition gateway -->
    <exclusiveGateway id="budgetGateway" name="Budget Available?" />

    <!-- DMN: Resolve manager-level approver group (DOA L2) -->
    <!-- Flowable 7.2: DMN evaluated only via serviceTask flowable:type="dmn" (not businessRuleTask). -->
    <!-- Output variable: approverGroup — read by managerApproval candidateGroups. -->
    <serviceTask id="resolveManagerGroup" name="Resolve Manager Approver Group" flowable:type="dmn">
      <extensionElements>
        <flowable:field name="decisionTableReferenceKey">
          <flowable:string>capex_manager_group</flowable:string>
        </flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Action Block: Manager Review -->
    <userTask id="managerApproval" name="Manager Review"
              flowable:actionType="HUMAN_APPROVAL"
              flowable:candidateGroups="${approverGroup},SUPER_ADMIN"
              flowable:formKey="capex-approval-form">
      <documentation>Finance manager reviews and approves, rejects, or escalates the CapEx request</documentation>
    </userTask>

    <!-- Per-level decision gateway: Manager -->
    <exclusiveGateway id="managerDecision" name="Manager Decision" />

    <!-- Amount threshold after manager approve -->
    <exclusiveGateway id="managerAmountGateway" name="Amount > $50,000?" />

    <!-- DMN: Resolve VP-level approver group (DOA L3) -->
    <!-- Receives flow from both managerDecision escalate and managerAmountGateway >50k. -->
    <serviceTask id="resolveVpGroup" name="Resolve VP Approver Group" flowable:type="dmn">
      <extensionElements>
        <flowable:field name="decisionTableReferenceKey">
          <flowable:string>capex_vp_group</flowable:string>
        </flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Action Block: VP Review -->
    <userTask id="vpApproval" name="VP Review"
              flowable:actionType="HUMAN_APPROVAL"
              flowable:candidateGroups="${approverGroup},SUPER_ADMIN"
              flowable:formKey="capex-approval-form">
      <documentation>Finance VP reviews CapEx requests over $50,000 or escalated from manager</documentation>
    </userTask>

    <!-- Per-level decision gateway: VP -->
    <exclusiveGateway id="vpDecision" name="VP Decision" />

    <!-- Amount threshold after VP approve -->
    <exclusiveGateway id="vpAmountGateway" name="Amount > $250,000?" />

    <!-- DMN: Resolve CFO-level approver group (DOA L4) -->
    <!-- Receives flow from both vpDecision escalate and vpAmountGateway >250k. -->
    <serviceTask id="resolveCfoGroup" name="Resolve CFO Approver Group" flowable:type="dmn">
      <extensionElements>
        <flowable:field name="decisionTableReferenceKey">
          <flowable:string>capex_cfo_group</flowable:string>
        </flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Action Block: CFO Review -->
    <userTask id="cfoApproval" name="CFO Review"
              flowable:actionType="HUMAN_APPROVAL"
              flowable:candidateGroups="${approverGroup},SUPER_ADMIN"
              flowable:formKey="capex-approval-form">
      <documentation>CFO reviews CapEx requests over $250,000 or escalated from VP</documentation>
    </userTask>

    <!-- Per-level decision gateway: CFO (top level — no escalate route) -->
    <exclusiveGateway id="cfoDecision" name="CFO Decision" />

    <!-- Action Block: Update CapEx Status to Approved + Reserve Budget -->
    <serviceTask id="updateApproved" name="Update Status: Approved"
                 flowable:actionType="EXTERNAL_API_CALL"
                 flowable:delegateExpression="${externalApiCallDelegate}">
      <extensionElements>
        <flowable:field name="connector"><flowable:string>capex-service</flowable:string></flowable:field>
        <flowable:field name="path"><flowable:string>/api/capex-requests/${capexRequestId}/approve</flowable:string></flowable:field>
        <flowable:field name="method"><flowable:string>PUT</flowable:string></flowable:field>
        <flowable:field name="responseVariable"><flowable:string>approvalResponse</flowable:string></flowable:field>
        <flowable:field name="onError"><flowable:string>CONTINUE</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Action Block: Send Approval Notification -->
    <serviceTask id="sendApprovalNotification" name="Send Approval Notification"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${notificationDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>${initiator}</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>capex-approved</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Action Block: Update CapEx Status to Rejected -->
    <serviceTask id="updateRejected" name="Update Status: Rejected"
                 flowable:actionType="EXTERNAL_API_CALL"
                 flowable:delegateExpression="${externalApiCallDelegate}">
      <extensionElements>
        <flowable:field name="connector"><flowable:string>capex-service</flowable:string></flowable:field>
        <flowable:field name="path"><flowable:string>/api/capex-requests/${capexRequestId}/reject</flowable:string></flowable:field>
        <flowable:field name="method"><flowable:string>PUT</flowable:string></flowable:field>
        <flowable:field name="responseVariable"><flowable:string>rejectionResponse</flowable:string></flowable:field>
        <flowable:field name="onError"><flowable:string>CONTINUE</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Action Block: Send Rejection Notification -->
    <serviceTask id="sendRejectionNotification" name="Send Rejection Notification"
                 flowable:actionType="NOTIFICATION"
                 flowable:delegateExpression="${notificationDelegate}">
      <extensionElements>
        <flowable:field name="channel"><flowable:string>email</flowable:string></flowable:field>
        <flowable:field name="recipient"><flowable:string>${initiator}</flowable:string></flowable:field>
        <flowable:field name="templateKey"><flowable:string>capex-rejected</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>

    <endEvent id="endEventApproved" name="Request Approved" />
    <endEvent id="endEventRejected" name="Request Rejected" />
    <endEvent id="endEventNoBudget" name="Insufficient Budget" />

    <!-- ===== Sequence Flows ===== -->

    <!-- Preamble: start → createCapExRequest → checkBudget → budgetGateway -->
    <sequenceFlow id="flow0" sourceRef="startEvent" targetRef="createCapExRequest" />
    <sequenceFlow id="flow1" sourceRef="createCapExRequest" targetRef="checkBudget" />
    <sequenceFlow id="flow2" sourceRef="checkBudget" targetRef="budgetGateway" />

    <!-- Budget gate -->
    <sequenceFlow id="flow3" sourceRef="budgetGateway" targetRef="resolveManagerGroup">
      <conditionExpression xsi:type="tFormalExpression">${budgetAvailable == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow4" sourceRef="budgetGateway" targetRef="endEventNoBudget">
      <conditionExpression xsi:type="tFormalExpression">${budgetAvailable != true}</conditionExpression>
    </sequenceFlow>

    <!-- Manager DMN → Manager task -->
    <sequenceFlow id="flowRM" sourceRef="resolveManagerGroup" targetRef="managerApproval" />

    <!-- Manager → managerDecision -->
    <sequenceFlow id="flow5" sourceRef="managerApproval" targetRef="managerDecision" />

    <!-- managerDecision branches -->
    <sequenceFlow id="flow6a" sourceRef="managerDecision" targetRef="updateRejected">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'reject'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow6b" sourceRef="managerDecision" targetRef="managerAmountGateway">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'approve'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow6c" sourceRef="managerDecision" targetRef="resolveVpGroup">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'escalate'}</conditionExpression>
    </sequenceFlow>

    <!-- managerAmountGateway branches -->
    <sequenceFlow id="flow7a" sourceRef="managerAmountGateway" targetRef="resolveVpGroup">
      <conditionExpression xsi:type="tFormalExpression">${requestAmount > 50000}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow7b" sourceRef="managerAmountGateway" targetRef="updateApproved">
      <conditionExpression xsi:type="tFormalExpression">${requestAmount &lt;= 50000}</conditionExpression>
    </sequenceFlow>

    <!-- VP DMN → VP task -->
    <sequenceFlow id="flowRVP" sourceRef="resolveVpGroup" targetRef="vpApproval" />

    <!-- VP → vpDecision -->
    <sequenceFlow id="flow8" sourceRef="vpApproval" targetRef="vpDecision" />

    <!-- vpDecision branches -->
    <sequenceFlow id="flow9a" sourceRef="vpDecision" targetRef="updateRejected">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'reject'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow9b" sourceRef="vpDecision" targetRef="vpAmountGateway">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'approve'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow9c" sourceRef="vpDecision" targetRef="resolveCfoGroup">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'escalate'}</conditionExpression>
    </sequenceFlow>

    <!-- vpAmountGateway branches -->
    <sequenceFlow id="flow10a" sourceRef="vpAmountGateway" targetRef="resolveCfoGroup">
      <conditionExpression xsi:type="tFormalExpression">${requestAmount > 250000}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow10b" sourceRef="vpAmountGateway" targetRef="updateApproved">
      <conditionExpression xsi:type="tFormalExpression">${requestAmount &lt;= 250000}</conditionExpression>
    </sequenceFlow>

    <!-- CFO DMN → CFO task -->
    <sequenceFlow id="flowRCFO" sourceRef="resolveCfoGroup" targetRef="cfoApproval" />

    <!-- CFO → cfoDecision -->
    <sequenceFlow id="flow11" sourceRef="cfoApproval" targetRef="cfoDecision" />

    <!-- cfoDecision branches (approve/reject only — no escalate at top level) -->
    <sequenceFlow id="flow12a" sourceRef="cfoDecision" targetRef="updateApproved">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'approve'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow12b" sourceRef="cfoDecision" targetRef="updateRejected">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'reject'}</conditionExpression>
    </sequenceFlow>

    <!-- Approved path -->
    <sequenceFlow id="flow13" sourceRef="updateApproved" targetRef="sendApprovalNotification" />
    <sequenceFlow id="flow14" sourceRef="sendApprovalNotification" targetRef="endEventApproved" />

    <!-- Rejected path -->
    <sequenceFlow id="flow15" sourceRef="updateRejected" targetRef="sendRejectionNotification" />
    <sequenceFlow id="flow16" sourceRef="sendRejectionNotification" targetRef="endEventRejected" />

    <!-- Non-interrupting SLA timers — one per approval level, shared SLA-Breached end event -->
    <boundaryEvent id="slaTimerManager" attachedToRef="managerApproval" cancelActivity="false">
      <timerEventDefinition>
        <timeDuration>${execution.getVariable('slaDuration') != null ? execution.getVariable('slaDuration') : 'PT15M'}</timeDuration>
      </timerEventDefinition>
    </boundaryEvent>
    <sequenceFlow id="flowSlaManager" sourceRef="slaTimerManager" targetRef="endEventSlaBreached"/>

    <boundaryEvent id="slaTimerVp" attachedToRef="vpApproval" cancelActivity="false">
      <timerEventDefinition>
        <timeDuration>${execution.getVariable('slaDuration') != null ? execution.getVariable('slaDuration') : 'PT15M'}</timeDuration>
      </timerEventDefinition>
    </boundaryEvent>
    <sequenceFlow id="flowSlaVp" sourceRef="slaTimerVp" targetRef="endEventSlaBreached"/>

    <boundaryEvent id="slaTimerCfo" attachedToRef="cfoApproval" cancelActivity="false">
      <timerEventDefinition>
        <timeDuration>${execution.getVariable('slaDuration') != null ? execution.getVariable('slaDuration') : 'PT15M'}</timeDuration>
      </timerEventDefinition>
    </boundaryEvent>
    <sequenceFlow id="flowSlaCfo" sourceRef="slaTimerCfo" targetRef="endEventSlaBreached"/>

    <endEvent id="endEventSlaBreached" name="SLA Breached"/>

  </process>

  <!--
    BPMNDI — left-to-right laddered layout (V4).
    Budget/preamble unchanged (x≤595). Manager row y≈280, VP row y≈170, CFO row y≈60.
    Three DMN resolver tasks inserted before each user task.
    All elements from managerApproval shifted +180px on x-axis; VP section +250; CFO section +340.
    Outcome tasks/notifications/ends shifted +360px from their V3 positions.
  -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_capex-approval-process">
    <bpmndi:BPMNPlane id="BPMNPlane_capex-approval-process" bpmnElement="capex-approval-process">

      <!-- Preamble shapes (unchanged) -->
      <bpmndi:BPMNShape id="startEvent_di" bpmnElement="startEvent">
        <omgdc:Bounds x="152" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="128" y="305" width="84" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="createCapExRequest_di" bpmnElement="createCapExRequest">
        <omgdc:Bounds x="240" y="240" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="checkBudget_di" bpmnElement="checkBudget">
        <omgdc:Bounds x="390" y="240" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="budgetGateway_di" bpmnElement="budgetGateway" isMarkerVisible="true">
        <omgdc:Bounds x="545" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="526" y="312" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endEventNoBudget_di" bpmnElement="endEventNoBudget">
        <omgdc:Bounds x="547" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="520" y="435" width="90" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Manager tier -->
      <bpmndi:BPMNShape id="resolveManagerGroup_di" bpmnElement="resolveManagerGroup">
        <omgdc:Bounds x="660" y="255" width="100" height="60" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="managerApproval_di" bpmnElement="managerApproval">
        <omgdc:Bounds x="830" y="240" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="managerDecision_di" bpmnElement="managerDecision" isMarkerVisible="true">
        <omgdc:Bounds x="990" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="972" y="312" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="managerAmountGateway_di" bpmnElement="managerAmountGateway" isMarkerVisible="true">
        <omgdc:Bounds x="1100" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="1078" y="312" width="94" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- VP tier -->
      <bpmndi:BPMNShape id="resolveVpGroup_di" bpmnElement="resolveVpGroup">
        <omgdc:Bounds x="1230" y="145" width="100" height="60" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="vpApproval_di" bpmnElement="vpApproval">
        <omgdc:Bounds x="1390" y="130" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="vpDecision_di" bpmnElement="vpDecision" isMarkerVisible="true">
        <omgdc:Bounds x="1550" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="1537" y="202" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="vpAmountGateway_di" bpmnElement="vpAmountGateway" isMarkerVisible="true">
        <omgdc:Bounds x="1670" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="1648" y="202" width="94" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- CFO tier -->
      <bpmndi:BPMNShape id="resolveCfoGroup_di" bpmnElement="resolveCfoGroup">
        <omgdc:Bounds x="1780" y="35" width="100" height="60" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="cfoApproval_di" bpmnElement="cfoApproval">
        <omgdc:Bounds x="1940" y="20" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="cfoDecision_di" bpmnElement="cfoDecision" isMarkerVisible="true">
        <omgdc:Bounds x="2100" y="35" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="2088" y="92" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Outcome tasks and end events -->
      <bpmndi:BPMNShape id="updateApproved_di" bpmnElement="updateApproved">
        <omgdc:Bounds x="2240" y="170" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sendApprovalNotification_di" bpmnElement="sendApprovalNotification">
        <omgdc:Bounds x="2400" y="170" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endEventApproved_di" bpmnElement="endEventApproved">
        <omgdc:Bounds x="2562" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="2540" y="235" width="80" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="updateRejected_di" bpmnElement="updateRejected">
        <omgdc:Bounds x="2240" y="350" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sendRejectionNotification_di" bpmnElement="sendRejectionNotification">
        <omgdc:Bounds x="2400" y="350" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endEventRejected_di" bpmnElement="endEventRejected">
        <omgdc:Bounds x="2562" y="372" width="36" height="36" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="2540" y="415" width="80" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Preamble edges (unchanged) -->
      <bpmndi:BPMNEdge id="flow0_di" bpmnElement="flow0">
        <omgdi:waypoint x="188" y="280" /><omgdi:waypoint x="240" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow1_di" bpmnElement="flow1">
        <omgdi:waypoint x="340" y="280" /><omgdi:waypoint x="390" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow2_di" bpmnElement="flow2">
        <omgdi:waypoint x="490" y="280" /><omgdi:waypoint x="545" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow3_di" bpmnElement="flow3">
        <omgdi:waypoint x="595" y="280" /><omgdi:waypoint x="660" y="285" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow4_di" bpmnElement="flow4">
        <omgdi:waypoint x="565" y="305" /><omgdi:waypoint x="565" y="410" /><omgdi:waypoint x="547" y="410" />
      </bpmndi:BPMNEdge>

      <!-- Manager tier edges -->
      <bpmndi:BPMNEdge id="flowRM_di" bpmnElement="flowRM">
        <omgdi:waypoint x="760" y="285" /><omgdi:waypoint x="830" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow5_di" bpmnElement="flow5">
        <omgdi:waypoint x="930" y="280" /><omgdi:waypoint x="990" y="280" />
      </bpmndi:BPMNEdge>
      <!-- managerDecision: reject → updateRejected -->
      <bpmndi:BPMNEdge id="flow6a_di" bpmnElement="flow6a">
        <omgdi:waypoint x="1015" y="305" /><omgdi:waypoint x="1015" y="390" /><omgdi:waypoint x="2240" y="390" />
      </bpmndi:BPMNEdge>
      <!-- managerDecision: approve → managerAmountGateway -->
      <bpmndi:BPMNEdge id="flow6b_di" bpmnElement="flow6b">
        <omgdi:waypoint x="1040" y="280" /><omgdi:waypoint x="1100" y="280" />
      </bpmndi:BPMNEdge>
      <!-- managerDecision: escalate → resolveVpGroup -->
      <bpmndi:BPMNEdge id="flow6c_di" bpmnElement="flow6c">
