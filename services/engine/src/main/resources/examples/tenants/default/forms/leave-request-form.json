{
  "id": "leave-request-form",
  "name": "Leave Request Form",
  "type": "default",
  "components": [
    {
      "type": "text",
      "text": "<h3>Leave Request Form</h3><p>Submit your leave request for approval.</p>"
    },
    {
      "type": "select",
      "key": "leaveType",
      "label": "Leave Type",
      "values": [
        { "label": "Annual Leave", "value": "annual" },
        { "label": "Sick Leave", "value": "sick" },
        { "label": "Personal Leave", "value": "personal" },
        { "label": "Parental Leave", "value": "parental" },
        { "label": "Bereavement Leave", "value": "bereavement" },
        { "label": "Unpaid Leave", "value": "unpaid" }
      ],
      "validate": {
        "required": true
      }
    },
    {
      "type": "datetime",
      "subtype": "date",
      "key": "startDate",
      "dateLabel": "Start Date",
      "validate": {
        "required": true
      }
    },
    {
      "type": "datetime",
      "subtype": "date",
      "key": "endDate",
      "dateLabel": "End Date",
      "validate": {
        "required": true
      }
    },
    {
      "type": "expression",
      "key": "leaveDays",
      "expression": "=if startDate != null and endDate != null and endDate >= startDate then (date(endDate) - date(startDate)) / duration(\"P1D\") + 1 else null",
      "computeOn": "change"
    },
    {
      "type": "text",
      "text": "**Total leave days:** {{leaveDays}}"
    },
    {
      "type": "textarea",
      "key": "reason",
      "label": "Reason for Leave",
      "placeholder": "Enter reason for leave request",
      "validate": {
        "required": true,
        "maxLength": 500
      }
    },
    {
      "type": "select",
      "key": "slaDuration",
      "label": "SLA Duration (testing)",
      "description": "Testing knob: time before the approval SLA timer fires. Leave as the default unless you are exercising the SLA-breach scenario.",
      "defaultValue": "PT15M",
      "values": [
        { "label": "Default (15 min)", "value": "PT15M" },
        { "label": "2 minutes", "value": "PT2M" },
        { "label": "5 minutes", "value": "PT5M" },
        { "label": "10 minutes", "value": "PT10M" },
        { "label": "1 hour", "value": "PT1H" },
        { "label": "1 day", "value": "P1D" }
      ],
      "validate": {
        "required": true
      }
    }
  ]
}
