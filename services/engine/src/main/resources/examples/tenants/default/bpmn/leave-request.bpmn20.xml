<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://werkflow.com/bpmn/examples">

  <process id="leave-request" name="Leave Request" isExecutable="true"
           flowable:versionTag="2">

    <documentation>Employee leave request workflow. A DMN decision evaluates whether formal
approval is required (and by whom) based on leave type and duration. Short casual leave is
auto-approved; longer or special-category leave is routed to the appropriate approver.</documentation>

    <extensionElements>
      <flowable:properties>
        <flowable:property name="category" value="examples"/>
      </flowable:properties>
    </extensionElements>

    <!-- Start Event -->
    <startEvent id="startEvent" name="Leave Request Submitted"
                flowable:formKey="leave-request-form"
                flowable:initiator="initiator">
      <documentation>Employee submits a leave request. Form fields: leaveType, leaveDays.</documentation>
    </startEvent>

    <!-- DMN: Resolve leave approval policy -->
    <!-- Flowable 7.2: DMN evaluated via serviceTask flowable:type="dmn". -->
    <!-- Outputs: approvalRequired (boolean), approverRole (string). -->
    <serviceTask id="resolveLeavePolicy" name="Resolve Leave Policy" flowable:type="dmn">
      <extensionElements>
        <flowable:field name="decisionTableReferenceKey">
          <flowable:string>leave_approval</flowable:string>
        </flowable:field>
      </extensionElements>
    </serviceTask>

    <!-- Gateway: does this leave require human approval? -->
    <exclusiveGateway id="autoApprovalGateway" name="Approval Required?"/>

    <!-- Manager/HR Review Task — only reached when approvalRequired == true -->
    <userTask id="managerReview" name="Manager Review"
              flowable:actionType="HUMAN_APPROVAL"
              flowable:candidateGroups="${approverRole},SUPER_ADMIN"
              flowable:formKey="leave-approval-form">
      <documentation>Approver reviews the leave request and sets decision = approve or reject.</documentation>
    </userTask>

    <!-- Decision Gateway -->
    <exclusiveGateway id="approvalGateway" name="Approved?"/>

    <!-- End Events -->
    <endEvent id="endAutoApproved" name="Auto Approved"/>
    <endEvent id="endApproved" name="Leave Approved"/>
    <endEvent id="endRejected" name="Leave Rejected"/>

    <!-- Sequence Flows -->
    <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="resolveLeavePolicy"/>
    <sequenceFlow id="flow2" sourceRef="resolveLeavePolicy" targetRef="autoApprovalGateway"/>

    <sequenceFlow id="flow3" sourceRef="autoApprovalGateway" targetRef="endAutoApproved">
      <conditionExpression xsi:type="tFormalExpression">${approvalRequired == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow4" sourceRef="autoApprovalGateway" targetRef="managerReview">
      <conditionExpression xsi:type="tFormalExpression">${approvalRequired == true}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow5" sourceRef="managerReview" targetRef="approvalGateway"/>

    <sequenceFlow id="flow6" sourceRef="approvalGateway" targetRef="endApproved">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'approve'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow7" sourceRef="approvalGateway" targetRef="endRejected">
      <conditionExpression xsi:type="tFormalExpression">${decision == 'reject'}</conditionExpression>
    </sequenceFlow>

    <!-- Non-interrupting SLA timer boundary: managerReview -->
    <boundaryEvent id="slaTimerManagerReview" attachedToRef="managerReview" cancelActivity="false">
      <timerEventDefinition>
        <timeDuration>${execution.getVariable('slaDuration') != null ? execution.getVariable('slaDuration') : 'PT15M'}</timeDuration>
      </timerEventDefinition>
    </boundaryEvent>
    <sequenceFlow id="flowSlaManagerReview" sourceRef="slaTimerManagerReview" targetRef="endEventSlaBreached"/>
    <endEvent id="endEventSlaBreached" name="SLA Breached"/>

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_leave-request">
    <bpmndi:BPMNPlane id="BPMNPlane_leave-request" bpmnElement="leave-request">

      <bpmndi:BPMNShape id="startEvent_di" bpmnElement="startEvent">
        <omgdc:Bounds x="152" y="262" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="125" y="305" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="resolveLeavePolicy_di" bpmnElement="resolveLeavePolicy">
        <omgdc:Bounds x="250" y="250" width="100" height="60"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="autoApprovalGateway_di" bpmnElement="autoApprovalGateway" isMarkerVisible="true">
        <omgdc:Bounds x="415" y="255" width="50" height="50"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="397" y="312" width="86" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="endAutoApproved_di" bpmnElement="endAutoApproved">
        <omgdc:Bounds x="422" y="152" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="397" y="195" width="86" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="managerReview_di" bpmnElement="managerReview">
        <omgdc:Bounds x="530" y="240" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="approvalGateway_di" bpmnElement="approvalGateway" isMarkerVisible="true">
        <omgdc:Bounds x="720" y="255" width="50" height="50"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="710" y="312" width="70" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="endApproved_di" bpmnElement="endApproved">
        <omgdc:Bounds x="842" y="172" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="816" y="215" width="82" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="endRejected_di" bpmnElement="endRejected">
        <omgdc:Bounds x="842" y="352" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="816" y="395" width="82" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="flow1_di" bpmnElement="flow1">
        <omgdi:waypoint x="188" y="280"/><omgdi:waypoint x="250" y="280"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow2_di" bpmnElement="flow2">
        <omgdi:waypoint x="350" y="280"/><omgdi:waypoint x="415" y="280"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow3_di" bpmnElement="flow3">
        <omgdi:waypoint x="440" y="255"/><omgdi:waypoint x="440" y="188"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow4_di" bpmnElement="flow4">
        <omgdi:waypoint x="465" y="280"/><omgdi:waypoint x="530" y="280"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow5_di" bpmnElement="flow5">
        <omgdi:waypoint x="650" y="280"/><omgdi:waypoint x="720" y="280"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow6_di" bpmnElement="flow6">
        <omgdi:waypoint x="745" y="255"/><omgdi:waypoint x="745" y="190"/><omgdi:waypoint x="842" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow7_di" bpmnElement="flow7">
        <omgdi:waypoint x="745" y="305"/><omgdi:waypoint x="745" y="370"/><omgdi:waypoint x="842" y="370"/>
      </bpmndi:BPMNEdge>

      <!-- SLA timer: non-interrupting boundary on managerReview -->
      <bpmndi:BPMNShape id="slaTimerManagerReview_di" bpmnElement="slaTimerManagerReview">
        <omgdc:Bounds x="632" y="302" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endEventSlaBreached_di" bpmnElement="endEventSlaBreached">
        <omgdc:Bounds x="632" y="380" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="610" y="423" width="80" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flowSlaManagerReview_di" bpmnElement="flowSlaManagerReview">
        <omgdi:waypoint x="650" y="338"/><omgdi:waypoint x="650" y="380"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
