{
  "id": "it-helpdesk-ticket-form",
  "name": "IT Helpdesk Ticket",
  "type": "default",
  "schemaVersion": 12,
  "components": [
    {
      "type": "text",
      "text": "<h3>IT Helpdesk Ticket</h3><p>Submit a request to the IT support team.</p>"
    },
    {
      "type": "textfield",
      "key": "subject",
      "label": "Subject",
      "placeholder": "Brief description of the issue",
      "validate": {
        "required": true,
        "minLength": 5,
        "maxLength": 200
      }
    },
    {
      "type": "textarea",
      "key": "description",
      "label": "Description",
      "placeholder": "Provide a detailed description of the issue"
    },
    {
      "type": "select",
      "key": "category",
      "label": "Category",
      "values": [
        { "label": "Hardware", "value": "Hardware" },
        { "label": "Software", "value": "Software" },
        { "label": "Access", "value": "Access" },
        { "label": "Other", "value": "Other" }
      ],
      "validate": {
        "required": true
      }
    },
    {
      "type": "select",
      "key": "priority",
      "label": "Priority",
      "values": [
        { "label": "Low", "value": "Low" },
        { "label": "Medium", "value": "Medium" },
        { "label": "High", "value": "High" }
      ],
      "validate": {
        "required": true
      }
    },
    {
      "type": "textfield",
      "key": "requesterEmail",
      "label": "Your Email Address",
      "placeholder": "Enter your email address",
      "validate": {
        "required": true,
        "validationType": "email"
      }
    },
    {
      "type": "select",
      "key": "slaDuration",
      "label": "SLA Duration (testing)",
      "description": "Testing knob: time before the ticket-resolution SLA timer fires. Leave as the default unless you are exercising the SLA-breach scenario.",
      "defaultValue": "PT15M",
      "values": [
        { "label": "Default (15 min)", "value": "PT15M" },
        { "label": "2 minutes", "value": "PT2M" },
        { "label": "5 minutes", "value": "PT5M" },
        { "label": "10 minutes", "value": "PT10M" },
        { "label": "1 hour", "value": "PT1H" },
        { "label": "1 day", "value": "P1D" }
      ],
      "validate": {
        "required": true
      }
    }
  ]
}
