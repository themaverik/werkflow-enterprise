<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://werkflow.com/bpmn/test">
  <process id="sample-service-task" name="Sample Service Task Fragment" isExecutable="true">
    <startEvent id="start"/>
    <sequenceFlow id="f1" sourceRef="start" targetRef="sampleTask"/>
    <serviceTask id="sampleTask" name="Sample Task"
                 flowable:delegateExpression="${sampleDelegate}"/>
    <sequenceFlow id="f2" sourceRef="sampleTask" targetRef="end"/>
    <endEvent id="end"/>
  </process>
</definitions>
