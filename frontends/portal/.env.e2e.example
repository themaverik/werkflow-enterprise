# E2E env for LOCAL Playwright runs.
# Copy to .env.e2e (gitignored) and fill E2E_PORTAL_CLIENT_SECRET.
# Load + run:  cd frontends/portal && set -a && . .env.e2e && set +a && npm run e2e

# Backend URLs — defaults match the local Docker stack.
E2E_ENGINE_URL=http://localhost:8081
E2E_KEYCLOAK_URL=http://localhost:8090

# werkflow-portal client secret — MUST match the LOCAL realm's client secret.
# Find it in config/env/.env.shared  →  KEYCLOAK_CLIENT_SECRET
E2E_PORTAL_CLIENT_SECRET=

# Test users — created/reset by infrastructure/keycloak/setup-local-e2e.sh.
# Default password there is Werkflow@2026! (override via E2E_TEST_PASSWORD when running the script).
E2E_ADMIN_USER=admin
E2E_ADMIN_PASSWORD=Werkflow@2026!
E2E_MANAGER_USER=john.manager
E2E_MANAGER_PASSWORD=Werkflow@2026!
E2E_EMPLOYEE_USER=jane.employee
E2E_EMPLOYEE_PASSWORD=Werkflow@2026!
