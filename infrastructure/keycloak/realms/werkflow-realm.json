      { "name": "leave_request_approver", "description": "Approve leave requests" },
      { "name": "department_poc", "description": "Department point of contact" },
      { "name": "department_head", "description": "Department head authority" },
      { "name": "driver", "description": "Transport driver" },
      { "name": "warehouse_staff", "description": "Warehouse staff" },
      {
        "name": "hr_manager",
        "description": "HR department manager",
        "composite": true,
        "composites": { "realm": ["asset_request_approver", "doa_approver_level1"] }
      },
      {
        "name": "hr_head",
        "description": "HR department head",
        "composite": true,
        "composites": { "realm": ["asset_request_approver", "doa_approver_level2", "department_head"] }
