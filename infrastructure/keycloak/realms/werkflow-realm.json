{
  "realm": "werkflow",
  "enabled": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "passwordPolicy": "length(8)",
  "clients": [
    {
      "clientId": "werkflow-portal",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "ci-client-secret",
      "redirectUris": [
        "http://localhost:4000/*",
        "http://localhost:4000/api/auth/callback/keycloak"
      ],
      "webOrigins": [
        "http://localhost:4000"
      ],
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:4000/*"
      },
      "protocolMappers": [
        {
          "name": "tenant-id-hardcoded",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "tenant_id",
            "claim.value": "default",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "access.tokenResponse.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "werkflow-engine",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "engine-dev-secret-do-not-use-in-prod",
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "werkflow-admin",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "admin-dev-secret-do-not-use-in-prod",
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect"
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "User role"
      },
      {
        "name": "admin",
        "description": "Administrator role"
      },
      {
        "name": "workflow-designer",
        "description": "Workflow Designer"
      },
      {
        "name": "process-owner",
        "description": "Process Owner"
      },
      {
        "name": "doa_approver_level1",
        "description": "DOA Approver Level 1"
      },
      {
        "name": "doa_approver_level2",
        "description": "DOA Approver Level 2"
      },
      {
        "name": "doa_approver_level3",
        "description": "DOA Approver Level 3"
      },
      {
        "name": "doa_approver_level4",
        "description": "DOA Approver Level 4"
      },
      {
        "name": "ENGINE_SERVICE",
        "description": "Service-to-service principal for engine calling other internal services (M4.12 B.2)"
      },
      {
        "name": "ADMIN_SERVICE",
        "description": "Service-to-service principal for admin calling other internal services (M4.12 B.2)"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@werkflow.local",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    },
    {
      "username": "testuser",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "email": "testuser@werkflow.local",
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "workflow-designer",
        "doa_approver_level2"
      ]
    },
    {
      "username": "service-account-werkflow-portal",
      "enabled": true,
      "serviceAccountClientId": "werkflow-portal",
      "clientRoles": {
        "realm-management": [
          "view-realm",
          "query-users"
        ]
      }
    },
    {
      "username": "service-account-werkflow-engine",
      "enabled": true,
      "serviceAccountClientId": "werkflow-engine",
      "realmRoles": [
        "ENGINE_SERVICE"
      ]
    },
    {
      "username": "service-account-werkflow-admin",
      "enabled": true,
      "serviceAccountClientId": "werkflow-admin",
      "realmRoles": [
        "ADMIN_SERVICE"
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "oidc",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "946266379427-quk1e84mtj72o8caeaidsp4msdfb00li.apps.googleusercontent.com",
        "clientSecret": "REDACTED_GOOGLE_SECRET",
        "discoveryEndpoint": "https://accounts.google.com/.well-known/openid-configuration",
        "defaultScope": "openid email profile",
        "syncMode": "IMPORT",
        "useJwksUrl": "true"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "google-email-mapper",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "user.attribute": "email",
        "claim": "email"
      }
    },
    {
      "name": "google-first-name-mapper",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "user.attribute": "firstName",
        "claim": "given_name"
      }
    },
    {
      "name": "google-last-name-mapper",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "user.attribute": "lastName",
        "claim": "family_name"
      }
    },
    {
      "name": "google-user-role-mapper",
      "identityProviderAlias": "google",
      "identityProviderMapper": "hardcoded-role-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "role": "user"
      }
    }
  ]
}