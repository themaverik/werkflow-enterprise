        "composite": true,
        "composites": { "realm": ["asset_request_approver", "inventory_manager", "doa_approver_level2", "department_head"] }
      },
      {
        "name": "finance_manager",
        "description": "Finance department manager",
        "composite": true,
        "composites": { "realm": ["doa_approver_level1", "doa_approver_level2"] }
      },
      {
        "name": "finance_head",
        "description": "Finance department head / CFO",
        "composite": true,
        "composites": { "realm": ["doa_approver_level3", "doa_approver_level4", "department_head"] }
      },
      {
        "name": "procurement_manager",
        "description": "Procurement department manager",
        "composite": true,
        "composites": { "realm": ["procurement_approver", "doa_approver_level1"] }
      },
      {
        "name": "procurement_head",
        "description": "Procurement department head",
        "composite": true,
        "composites": { "realm": ["procurement_approver", "doa_approver_level2", "department_head"] }
      },
      {
        "name": "logistics_manager",
        "description": "Logistics / transport manager",
        "composite": true,
        "composites": { "realm": ["transport_approver", "doa_approver_level1"] }
      },
      {
        "name": "transport_head",
        "description": "Transport department head",
        "composite": true,
        "composites": { "realm": ["transport_approver", "department_head"] }
      },
      {
        "name": "central_hub_manager",
        "description": "Central hub manager",
        "composite": true,
        "composites": { "realm": ["hub_manager"] }
      }
    ]
  },
