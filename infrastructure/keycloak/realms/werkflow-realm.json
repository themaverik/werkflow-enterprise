  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "oidc",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "946266379427-quk1e84mtj72o8caeaidsp4msdfb00li.apps.googleusercontent.com",
        "clientSecret": "REDACTED_GOOGLE_SECRET",
        "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
        "tokenUrl": "https://oauth2.googleapis.com/token",
