# ================================================================
# DOCKER COMPOSE SHELL SUBSTITUTION VARIABLES
# ================================================================
# These vars are interpolated directly into docker-compose.yml at
# startup (not passed as container env vars via env_file).
# Copy this file to .env (same directory) and fill in real values.
# .env is gitignored — never commit it.
# ================================================================

# NextAuth JWT signing secret (portal container)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Keycloak client secret for werkflow-portal (portal container)
# Must match KEYCLOAK_PORTAL_CLIENT_SECRET in config/env/.env.shared
KEYCLOAK_CLIENT_SECRET=

# Keycloak client secret for werkflow-admin (admin-service container)
# Matches the werkflow-admin client secret in Keycloak
KEYCLOAK_ADMIN_CLIENT_SECRET=
